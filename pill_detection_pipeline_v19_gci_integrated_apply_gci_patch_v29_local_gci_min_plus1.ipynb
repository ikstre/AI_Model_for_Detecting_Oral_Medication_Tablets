    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"c2cbc57e\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# (디버그) 실제 Trainer args 확인 (amp/nbs/workers/pin_memory 등)\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _print_trainer_args(yolo_model):\\n\",\n",
    "    \"    tr = getattr(yolo_model, \\\"trainer\\\", None)\\n\",\n",
    "    \"    if tr is None:\\n\",\n",
    "    \"        print(\\\"trainer: None (train 실행 후 확인 가능합니다)\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"    args = getattr(tr, \\\"args\\\", None)\\n\",\n",
    "    \"    if args is None:\\n\",\n",
    "    \"        print(\\\"trainer.args: None\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _get(name, default=None):\\n\",\n",
    "    \"        return getattr(args, name, default)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\\"trainer.args.batch      :\\\", _get(\\\"batch\\\"))\\n\",\n",
    "    \"    print(\\\"trainer.args.imgsz      :\\\", _get(\\\"imgsz\\\"))\\n\",\n",
    "    \"    print(\\\"trainer.args.amp        :\\\", _get(\\\"amp\\\"))\\n\",\n",
    "    \"    print(\\\"trainer.args.nbs        :\\\", _get(\\\"nbs\\\"))\\n\",\n",
    "    \"    print(\\\"trainer.args.workers    :\\\", _get(\\\"workers\\\"))\\n\",\n",
    "    \"    print(\\\"trainer.args.cache      :\\\", _get(\\\"cache\\\"))\\n\",\n",
    "    \"    print(\\\"trainer.args.pin_memory :\\\", _get(\\\"pin_memory\\\", \\\"<not-exposed>\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if torch.cuda.is_available():\\n\",\n",
    "    \"        free, total = torch.cuda.mem_get_info()\\n\",\n",
    "    \"        print(f\\\"CUDA mem (free/total): {free/1e9:.2f}GB / {total/1e9:.2f}GB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"_print_trainer_args(final_model)\\n\"\n",
    "   ],\n",
