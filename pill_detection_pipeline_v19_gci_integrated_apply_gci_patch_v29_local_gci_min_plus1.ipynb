    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"e68b162d\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6) COCOeval mAP@[0.75:0.95]\\n\",\n",
    "    \"\\n\",\n",
    "    \"- val split을 COCO로 저장\\n\",\n",
    "    \"- YOLO val 추론 결과를 COCO dt 형식으로 변환해서 평가\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"814bb37a\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 6) val GT COCO 저장 (평가에서 사용할 파일)\\n\",\n",
    "    \"# - pill_preprocess.save_coco_json은 parent dir를 자동 생성합니다.\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_gt_path = save_coco_json(val_coco, Path(cfg.export_dir)/\\\"val_gt.json\\\")\\n\",\n",
    "    \"val_gt_path\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"2214ac29\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# (진단) 학습 결과(best.pt) 저장 위치 확인\\n\",\n",
    "    \"# - Windows/Mac 혼용 환경에서도 동일하게 확인 가능\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import glob\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _print_tree(root, max_depth=3):\\n\",\n",
    "    \"    root = Path(root)\\n\",\n",
    "    \"    if not root.exists():\\n\",\n",
    "    \"        print(f\\\"[X] not found: {root}\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"    print(f\\\"[OK] {root.resolve()}\\\")\\n\",\n",
    "    \"    base_depth = len(root.parts)\\n\",\n",
    "    \"    for p in sorted(root.rglob(\\\"*\\\")):\\n\",\n",
    "    \"        depth = len(p.parts) - base_depth\\n\",\n",
    "    \"        if depth > max_depth:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        prefix = \\\"  \\\" * depth\\n\",\n",
    "    \"        if p.is_dir():\\n\",\n",
    "    \"            print(f\\\"{prefix}📁 {p.name}\\\")\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            print(f\\\"{prefix}📄 {p.name}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"CWD:\\\", Path().resolve())\\n\",\n",
    "    \"print(\\\"cfg.work_dir:\\\", cfg.work_dir)\\n\",\n",
    "    \"_print_tree(cfg.work_dir, max_depth=4)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# best/last 후보를 한 번에 스캔\\n\",\n",
    "    \"patterns = [\\n\",\n",
    "    \"    str(Path(cfg.work_dir)/\\\"**\\\"/\\\"weights\\\"/\\\"best.pt\\\"),\\n\",\n",
    "    \"    str(Path(cfg.work_dir)/\\\"**\\\"/\\\"weights\\\"/\\\"last.pt\\\"),\\n\",\n",
    "    \"    str(Path(\\\"runs\\\")/\\\"**\\\"/\\\"weights\\\"/\\\"best.pt\\\"),\\n\",\n",
    "    \"    str(Path(\\\"runs\\\")/\\\"**\\\"/\\\"weights\\\"/\\\"last.pt\\\"),\\n\",\n",
    "    \"]\\n\",\n",
    "    \"hits = []\\n\",\n",
    "    \"for pat in patterns:\\n\",\n",
    "    \"    hits += glob.glob(pat, recursive=True)\\n\",\n",
    "    \"hits = [p for p in hits if Path(p).is_file()]\\n\",\n",
    "    \"hits = sorted(hits, key=lambda p: Path(p).stat().st_mtime, reverse=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n[FOUND WEIGHTS]\\\")\\n\",\n",
    "    \"if not hits:\\n\",\n",
    "    \"    print(\\\"  - weights 파일을 찾지 못했습니다. (베이스라인 학습 셀부터 실행해 주세요)\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    for p in hits[:20]:\\n\",\n",
    "    \"        print(\\\"  -\\\", p)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"235b3297\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# (평가 준비) best.pt 경로를 \\\"학습 결과 save_dir\\\"에서 안전하게 가져오기\\n\",\n",
    "    \"# - Ultralytics는 baseline, baseline2 처럼 이름을 바꿔 저장할 수 있어 고정 경로 가정이 깨질 수 있습니다.\\n\",\n",
    "    \"# - 또한 project/name을 주지 않으면 기본 runs/detect/... 아래로 저장됩니다.\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import glob\\n\",\n",
    "    \"\\n\",\n",
    "    \"def resolve_best_pt(*roots, preferred_name=\\\"baseline\\\"):\\n\",\n",
    "    \"    # roots: 검색할 루트 폴더들 (예: cfg.work_dir, \\\"runs\\\", \\\"runs/detect\\\")\\n\",\n",
    "    \"    roots = [str(r) for r in roots if r is not None]\\n\",\n",
    "    \"    # 중복 제거\\n\",\n",
    "    \"    seen = set()\\n\",\n",
    "    \"    roots = [r for r in roots if not (r in seen or seen.add(r))]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    patterns = []\\n\",\n",
    "    \"    for root in roots:\\n\",\n",
    "    \"        patterns += [\\n\",\n",
    "    \"            str(Path(root) / f\\\"{preferred_name}*\\\" / \\\"weights\\\" / \\\"best.pt\\\"),\\n\",\n",
    "    \"            str(Path(root) / \\\"**\\\" / \\\"weights\\\" / \\\"best.pt\\\"),\\n\",\n",
    "    \"            str(Path(root) / \\\"**\\\" / \\\"best.pt\\\"),\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cand = []\\n\",\n",
    "    \"    for pat in patterns:\\n\",\n",
    "    \"        cand += glob.glob(pat, recursive=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 존재하는 파일만\\n\",\n",
    "    \"    cand = [p for p in cand if Path(p).is_file()]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not cand:\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cand = sorted(cand, key=lambda p: Path(p).stat().st_mtime, reverse=True)\\n\",\n",
    "    \"    return Path(cand[0])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ✅ work_dir 우선, 그다음 Ultralytics 기본 runs 경로까지 fallback\\n\",\n",
    "    \"best_pt = resolve_best_pt(\\n\",\n",
    "    \"    cfg.work_dir,\\n\",\n",
    "    \"    \\\"runs\\\",\\n\",\n",
    "    \"    Path(\\\"runs\\\")/\\\"detect\\\",\\n\",\n",
    "    \"    preferred_name=getattr(cfg, \\\"baseline_name\\\", \\\"baseline\\\"),\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"if best_pt is None or (not best_pt.exists()):\\n\",\n",
    "    \"    raise FileNotFoundError(\\n\",\n",
    "    \"        \\\"best.pt를 찾지 못했습니다. 아래 진단 셀을 먼저 실행해 주세요.\\\\n\\\"\\n\",\n",
    "    \"        f\\\"- cfg.work_dir='{cfg.work_dir}'\\\\n\\\"\\n\",\n",
    "    \"        \\\"- (가능성 1) 베이스라인 학습 셀을 아직 실행하지 않음\\\\n\\\"\\n\",\n",
    "    \"        \\\"- (가능성 2) 학습이 중간에 실패/중단되어 weights가 저장되지 않음\\\\n\\\"\\n\",\n",
    "    \"        \\\"- (가능성 3) project/name이 적용되지 않아 runs/detect/... 에 저장됨\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"✅ best.pt:\\\", best_pt)\\n\",\n",
    "    \"best_model = YOLO(str(best_pt))\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"9f84b980\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7) Optuna tuning (선택)\\n\",\n",
    "    \"\\n\",\n",
    "    \"- trial마다 짧게 학습 → val mAP@[0.75:0.95]로 최적화\\n\",\n",
    "    \"- 시간이 길면 `epochs`를 줄이고 trial 수를 적게 시작하세요.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"7d23f50a9abc7c90\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# YOLO 예측 -> COCO detection(list) 변환 + mAP@[0.75:0.95] 평가 유틸\\n\",\n",
    "    \"# (v7에서 누락된 함수 복원 + Windows cp949 UnicodeDecodeError 대응)\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"\\n\",\n",
    "    \"def yolo_predict_to_coco_dt(model, cfg, coco_images, catid_to_yolo, yolo_to_catid):\\n\",\n",
    "    \"    # coco_images: list of {\\\"id\\\",\\\"file_name\\\",\\\"width\\\",\\\"height\\\"...}\\n\",\n",
    "    \"    dts = []\\n\",\n",
    "    \"    for im in coco_images:\\n\",\n",
    "    \"        img_path = resolve_train_image_path(cfg.train_img_dir, im[\\\"file_name\\\"])\\n\",\n",
    "    \"        if img_path is None:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        res = model.predict(\\n\",\n",
    "    \"            source=str(img_path),\\n\",\n",
    "    \"            conf=float(getattr(cfg, 'eval_conf', cfg.conf)),\\n\",\n",
    "    \"            iou=float(getattr(cfg, 'eval_iou', cfg.iou)),\\n\",\n",
    "    \"            max_det=int(getattr(cfg,'max_det',300)),\\n\",\n",
    "    \"            verbose=False\\n\",\n",
    "    \"        )[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        boxes = res.boxes\\n\",\n",
    "    \"        if boxes is None or len(boxes) == 0:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        xyxy = boxes.xyxy.cpu().numpy()\\n\",\n",
    "    \"        conf = boxes.conf.cpu().numpy()\\n\",\n",
    "    \"        cls  = boxes.cls.cpu().numpy().astype(int)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # score 내림차순 정렬 후, 도메인 제약(최대 N개) 반영\\n\",\n",
    "    \"        order = np.argsort(-conf)\\n\",\n",
    "    \"        max_keep = int(getattr(cfg, \\\"max_det_per_image\\\", 0) or 0)\\n\",\n",
    "    \"        if max_keep > 0:\\n\",\n",
    "    \"            order = order[:max_keep]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        xyxy = xyxy[order]\\n\",\n",
    "    \"        conf = conf[order]\\n\",\n",
    "    \"        cls  = cls[order]\\n\",\n",
    "    \"        for (x1,y1,x2,y2), sc, c in zip(xyxy, conf, cls):\\n\",\n",
    "    \"            cid = yolo_to_catid.get(int(c))\\n\",\n",
    "    \"            if cid is None:\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"            w = float(x2 - x1)\\n\",\n",
    "    \"            h = float(y2 - y1)\\n\",\n",
    "    \"            dts.append({\\n\",\n",
    "    \"                \\\"image_id\\\": int(im[\\\"id\\\"]),            # ✅ GT image_id 그대로\\n\",\n",
    "    \"                \\\"category_id\\\": int(cid),              # ✅ 원본 category_id\\n\",\n",
    "    \"                \\\"bbox\\\": [float(x1), float(y1), w, h],\\n\",\n",
    "    \"                \\\"score\\\": float(sc)\\n\",\n",
    "    \"            })\\n\",\n",
    "    \"    return dts\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def coco_load_utf8(gt_json_path):\\n\",\n",
    "    \"    # pycocotools.COCO는 내부에서 open(..., encoding=...)을 지정하지 않아\\n\",\n",
    "    \"    # Windows(cp949) 환경에서 UnicodeDecodeError가 날 수 있습니다.\\n\",\n",
    "    \"    # -> UTF-8로 직접 로드한 뒤 createIndex()로 인덱스를 생성합니다.\\n\",\n",
    "    \"    coco = COCO()\\n\",\n",
    "    \"    with open(gt_json_path, \\\"r\\\", encoding=\\\"utf-8-sig\\\") as f:\\n\",\n",
    "    \"        coco.dataset = json.load(f)\\n\",\n",
    "    \"    coco.createIndex()\\n\",\n",
    "    \"    return coco\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def coco_map_075_095(gt_json_path, dt_list, *, max_det=4, iou_min=0.75, iou_max=0.95,\\n\",\n",
    "    \"                     verbose: bool=False, return_cocoeval: bool=False):\\n\",\n",
    "    \"    \\\"\\\"\\\"COCOeval로 mAP@IoU=[0.75:0.95] (area=all, maxDets=max_det)만 안전하게 계산합니다.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    - COCOeval.summarize()의 기본 출력은 (0.50:0.95, maxDets=[1,10,100]) 전제를 깔고 있어\\n\",\n",
    "    \"      iouThrs/maxDets를 바꾸면 -1.000 라인이 섞여 보일 수 있습니다.\\n\",\n",
    "    \"    - 여기서는 cocoEval.eval['precision'] 텐서를 직접 평균내서, 우리가 쓰는 지표 1개만 반환합니다.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    if dt_list is None or len(dt_list) == 0:\\n\",\n",
    "    \"        return (0.0, None) if return_cocoeval else 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cocoGt = COCO(str(gt_json_path))\\n\",\n",
    "    \"    cocoDt = cocoGt.loadRes(dt_list)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cocoEval = COCOeval(cocoGt, cocoDt, iouType=\\\"bbox\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # IoU grid: 0.75..0.95 step 0.05 (linspace로 float 정합 이슈 완화)\\n\",\n",
    "    \"    nT = int(round((float(iou_max) - float(iou_min)) / 0.05)) + 1\\n\",\n",
    "    \"    cocoEval.params.iouThrs = np.linspace(float(iou_min), float(iou_max), nT)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 제출 제한과 동일하게 maxDets를 맞춤\\n\",\n",
    "    \"    cocoEval.params.maxDets = [1, int(max_det), int(max_det)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cocoEval.evaluate()\\n\",\n",
    "    \"    cocoEval.accumulate()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if verbose:\\n\",\n",
    "    \"        cocoEval.summarize()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # precision: [T, R, K, A, M]\\n\",\n",
    "    \"    prec = cocoEval.eval[\\\"precision\\\"]\\n\",\n",
    "    \"    if prec is None:\\n\",\n",
    "    \"        ap = 0.0\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        # area=all, maxDet=max_det bucket\\n\",\n",
    "    \"        aind = cocoEval.params.areaRngLbl.index(\\\"all\\\")\\n\",\n",
    "    \"        mind = len(cocoEval.params.maxDets) - 1\\n\",\n",
    "    \"        p = prec[:, :, :, aind, mind]\\n\",\n",
    "    \"        p = p[p > -1]  # -1은 해당 bucket에서 GT가 없어 undefined인 경우\\n\",\n",
    "    \"        ap = float(p.mean()) if p.size else 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return (ap, cocoEval) if return_cocoeval else ap\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"c5d5722a\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"import gc\\n\",\n",
    "    \"import optuna\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _pick_weight_from_save_dir(save_dir):\\n\",\n",
    "    \"    save_dir = Path(save_dir)\\n\",\n",
    "    \"    best = save_dir / \\\"weights\\\" / \\\"best.pt\\\"\\n\",\n",
    "    \"    last = save_dir / \\\"weights\\\" / \\\"last.pt\\\"\\n\",\n",
    "    \"    if best.exists():\\n\",\n",
    "    \"        return best\\n\",\n",
    "    \"    if last.exists():\\n\",\n",
    "    \"        return last\\n\",\n",
    "    \"    cands = list(save_dir.rglob(\\\"best.pt\\\")) + list(save_dir.rglob(\\\"last.pt\\\"))\\n\",\n",
    "    \"    if cands:\\n\",\n",
    "    \"        cands.sort(key=lambda p: p.stat().st_mtime, reverse=True)\\n\",\n",
    "    \"        return cands[0]\\n\",\n",
    "    \"    return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def objective(trial):\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    # 1) 하이퍼파라미터 샘플링\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    imgsz = int(getattr(cfg, 'imgsz', 640))  # ✅ 고정(요청: imgsz 변경 제외)\\n\",\n",
    "    \"    batch = trial.suggest_categorical('batch', [4, 8])  # ✅ VRAM 8GB 고려\\n\",\n",
    "    \"    lr0   = trial.suggest_float(\\\"lr0\\\", 1e-4, 5e-2, log=True)\\n\",\n",
    "    \"    wd    = trial.suggest_float(\\\"weight_decay\\\", 0.0, 5e-3)\\n\",\n",
    "    \"    optimizer = trial.suggest_categorical(\\\"optimizer\\\", [\\\"SGD\\\", \\\"AdamW\\\"])\\n\",\n",
    "    \"    model_name = trial.suggest_categorical(\\\"model\\\", list(getattr(cfg, \\\"model_candidates\\\", [cfg.base_model])))\\n\",\n",
    "    \"    mosaic = trial.suggest_float(\\\"mosaic\\\", 0.0, 1.0)\\n\",\n",
    "    \"    mixup  = trial.suggest_float(\\\"mixup\\\", 0.0, 0.3)\\n\",\n",
    "    \"    # affine / geometric augmentations (색상(hsv)은 0으로 고정)\\n\",\n",
    "    \"    degrees = trial.suggest_float(\\\"degrees\\\", 0.0, 20.0)\\n\",\n",
    "    \"    translate = trial.suggest_float(\\\"translate\\\", 0.0, 0.20)\\n\",\n",
    "    \"    scale = trial.suggest_float(\\\"scale\\\", 0.0, 0.50)\\n\",\n",
    "    \"    shear = trial.suggest_float(\\\"shear\\\", 0.0, 5.0)\\n\",\n",
    "    \"    perspective = trial.suggest_float(\\\"perspective\\\", 0.0, 0.001)\\n\",\n",
    "    \"    fliplr = trial.suggest_float(\\\"fliplr\\\", 0.0, 0.50)\\n\",\n",
    "    \"    flipud = trial.suggest_float(\\\"flipud\\\", 0.0, 0.10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    # 2) 저장 경로(통일)\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    optuna_root = Path(cfg.work_dir) / cfg.optuna_subdir\\n\",\n",
    "    \"    optuna_root.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"    run_name = f\\\"trial_{trial.number:03d}\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    # 3) 모델 생성 + 콜백(프루너)\\n\",\n",
    "    \"    #    - \\\"중간 보고/프루닝\\\" 지표도 최종 목표와 동일하게:\\n\",\n",
    "    \"    #      mAP@[0.75:0.95] (COCOeval, IoU=0.75~0.95 평균)\\n\",\n",
    "    \"    #    - 매 epoch마다 full-val로 계산하면 느리므로,\\n\",\n",
    "    \"    #      cfg.optuna_eval_every(기본 2) epoch마다,\\n\",\n",
    "    \"    #      cfg.optuna_eval_n_images(기본 200)장만 샘플링해서 계산(프록시)\\n\",\n",
    "    \"    #    - trial 종료 후에는 full val로 최종 점수 계산\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    m = YOLO(str(model_name))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    eval_every = int(getattr(cfg, \\\"optuna_eval_every\\\", 2))\\n\",\n",
    "    \"    eval_n = int(getattr(cfg, \\\"optuna_eval_n_images\\\", 200))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 고정 서브셋(재현성): val 이미지 리스트를 file_name 기준 정렬 후 앞에서 eval_n개 사용\\n\",\n",
    "    \"    val_imgs_sorted = sorted(val_coco[\\\"images\\\"], key=lambda x: str(x.get(\\\"file_name\\\", \\\"\\\")))\\n\",\n",
    "    \"    val_subset = val_imgs_sorted[:min(eval_n, len(val_imgs_sorted))]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 콜백 상태\\n\",\n",
    "    \"    state = {\\\"last_report\\\": None, \\\"pruned\\\": False}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _on_fit_epoch_end(trainer):\\n\",\n",
    "    \"        epoch = int(getattr(trainer, \\\"epoch\\\", 0)) + 1\\n\",\n",
    "    \"        if eval_every > 1 and (epoch % eval_every != 0):\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        save_dir = getattr(trainer, \\\"save_dir\\\", None)\\n\",\n",
    "    \"        if save_dir is None:\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        weight_path = _pick_weight_from_save_dir(save_dir)\\n\",\n",
    "    \"        if weight_path is None:\\n\",\n",
    "    \"            return\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 현재 epoch 가중치로 평가\\n\",\n",
    "    \"        bm = YOLO(str(weight_path))\\n\",\n",
    "    \"        dt = yolo_predict_to_coco_dt(bm, cfg, val_subset, catid_to_yolo, yolo_to_catid)\\n\",\n",
    "    \"        score = coco_map_075_095(val_gt_path, dt, max_det=int(getattr(cfg, 'max_det_per_image', 4)))\\n\",\n",
    "    \"        if score is None or (isinstance(score, float) and (np.isnan(score) or score < 0)):\\n\",\n",
    "    \"            score = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # report + prune 판단\\n\",\n",
    "    \"        state[\\\"last_report\\\"] = float(score)\\n\",\n",
    "    \"        trial.report(float(score), step=epoch)\\n\",\n",
    "    \"        if trial.should_prune():\\n\",\n",
    "    \"            state[\\\"pruned\\\"] = True\\n\",\n",
    "    \"            # Ultralytics 쪽에서 학습을 정상 종료시키는 플래그(지원되는 버전에서 동작)\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                trainer.stop = True\\n\",\n",
    "    \"            except Exception:\\n\",\n",
    "    \"                pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 메모리 정리(연속 epoch 안정화)\\n\",\n",
    "    \"        del bm\\n\",\n",
    "    \"        gc.collect()\\n\",\n",
    "    \"        if torch.cuda.is_available():\\n\",\n",
    "    \"            torch.cuda.empty_cache()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 콜백 등록\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        m.add_callback(\\\"on_fit_epoch_end\\\", _on_fit_epoch_end)\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    # 4) 학습\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    results = m.train(\\n\",\n",
    "    \"        data=str(data_yaml),\\n\",\n",
    "    \"        imgsz=int(imgsz),\\n\",\n",
    "    \"        epochs=int(getattr(cfg, \\\"optuna_epochs\\\", 10)),\\n\",\n",
    "    \"        batch=int(batch),\\n\",\n",
    "    \"        lr0=float(lr0),\\n\",\n",
    "    \"        weight_decay=float(wd),\\n\",\n",
    "    \"        optimizer=str(optimizer),\\n\",\n",
    "    \"        mosaic=float(mosaic),\\n\",\n",
    "    \"        mixup=float(mixup),\\n\",\n",
    "    \"        # affine aug\\n\",\n",
    "    \"        hsv_h=0.0, hsv_s=0.0, hsv_v=0.0,\\n\",\n",
    "    \"        degrees=float(degrees),\\n\",\n",
    "    \"        translate=float(translate),\\n\",\n",
    "    \"        scale=float(scale),\\n\",\n",
    "    \"        shear=float(shear),\\n\",\n",
    "    \"        perspective=float(perspective),\\n\",\n",
    "    \"        fliplr=float(fliplr),\\n\",\n",
    "    \"        flipud=float(flipud),\\n\",\n",
    "    \"\\n\",\n",
    "    \"        project=str(optuna_root),\\n\",\n",
    "    \"        name=run_name,\\n\",\n",
    "    \"        exist_ok=True,\\n\",\n",
    "    \"        verbose=False,\\n\",\n",
    "    \"        device=getattr(cfg, \\\"device\\\", None),\\n\",\n",
    "    \"        workers=int(getattr(cfg, \\\"workers\\\", 0)),\\n\",\n",
    "    \"        amp=True,      # ✅ mixed precision (메모리↓)\\n\",\n",
    "    \"        nbs=16,        # ✅ nominal batch size (loss 정규화)\\n\",\n",
    "    \"        val=True,\\n\",\n",
    "    \"        save=True\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 콜백에서 조기중단된 경우 -> Optuna에는 \\\"pruned\\\"로 기록\\n\",\n",
    "    \"    if state.get(\\\"pruned\\\", False):\\n\",\n",
    "    \"        # 마지막 보고값이 있어야 pruner가 안정적으로 동작합니다.\\n\",\n",
    "    \"        # (없으면 그냥 prune 처리)\\n\",\n",
    "    \"        raise optuna.exceptions.TrialPruned()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    # 5) best/last 자동 탐색 후 최종 평가(mAP@[0.75:0.95], full-val)\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    save_dir = getattr(results, \\\"save_dir\\\", None)\\n\",\n",
    "    \"    if save_dir is None:\\n\",\n",
    "    \"        trainer = getattr(m, \\\"trainer\\\", None)\\n\",\n",
    "    \"        save_dir = getattr(trainer, \\\"save_dir\\\", None) if trainer is not None else None\\n\",\n",
    "    \"    if save_dir is None:\\n\",\n",
    "    \"        save_dir = optuna_root / run_name\\n\",\n",
    "    \"\\n\",\n",
    "    \"    weight_path = _pick_weight_from_save_dir(save_dir)\\n\",\n",
    "    \"    if weight_path is None or (not Path(weight_path).exists()):\\n\",\n",
    "    \"        raise FileNotFoundError(f\\\"weights를 찾지 못했습니다: save_dir={save_dir}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    bm = YOLO(str(weight_path))\\n\",\n",
    "    \"    dt = yolo_predict_to_coco_dt(bm, cfg, val_coco[\\\"images\\\"], catid_to_yolo, yolo_to_catid)\\n\",\n",
    "    \"    map_score = coco_map_075_095(val_gt_path, dt, max_det=int(getattr(cfg, 'max_det_per_image', 4)))\\n\",\n",
    "    \"    if map_score is None or (isinstance(map_score, float) and (np.isnan(map_score) or map_score < 0)):\\n\",\n",
    "    \"        map_score = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    # 6) 메모리 정리(연속 trial 안정화)\\n\",\n",
    "    \"    # ------------------------\\n\",\n",
    "    \"    del m, bm\\n\",\n",
    "    \"    gc.collect()\\n\",\n",
    "    \"    if torch.cuda.is_available():\\n\",\n",
    "    \"        torch.cuda.empty_cache()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return float(map_score)\\n\"\n",
    "   ],\n",
