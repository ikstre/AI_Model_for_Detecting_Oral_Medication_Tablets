    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Pill Detection Pipeline (IDs Preserved)\\n\",\n",
    "    \"\\n\",\n",
    "    \"요청사항 반영:\\n\",\n",
    "    \"- 제공된 JSON의 **image_id / category_id / annotation_id 체계는 그대로 유지**\\n\",\n",
    "    \"- 학습은 YOLO(ultralytics) 사용\\n\",\n",
    "    \"- Optuna로 하이퍼파라미터 탐색 가능\\n\",\n",
    "    \"- 평가: COCOeval로 **mAP@[0.75:0.95]** (IoU=0.75~0.95 step 0.05)\\n\",\n",
    "    \"- 제출: `annotation_id, image_id, category_id, bbox_x, bbox_y, bbox_w, bbox_h, score`\\n\",\n",
    "    \"  - image_id는 채점 키이므로, **테스트의 image_id 규칙**은 설정값으로 선택 가능\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"e60fda6d\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:56.654430600Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:52.895943500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# 필요시 설치\\n\",\n",
    "    \"# !pip -q install ultralytics==8.* pycocotools optuna pyyaml\\n\",\n",
    "    \"\\n\",\n",
    "    \"import random, sys\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"# 로컬 모듈 불러오기\\n\",\n",
    "    \"sys.path.append(str(Path(\\\".\\\").resolve()))\\n\",\n",
    "    \"from pill_preprocess_v3_robust import (\\n\",\n",
    "    \"    collect_json_files, merge_coco_from_many_json, sanitize_coco_inplace,\\n\",\n",
    "    \"    split_coco_by_image, build_cat_maps,\\n\",\n",
    "    \"    export_yolo_dataset, write_dataset_yaml, save_coco_json,\\n\",\n",
    "    \"    count_class_instances, compute_class_weight_from_coco, make_weighted_train_list, write_split_list,\\n\",\n",
    "    \"    build_train_like_image_id_map, parse_test_image_id\\n\",\n",
    "    \")\\n\",\n",
    "    \"from pill_model_setup_v4_max4_fixed import CFG, set_seed, build_yolo_model, train_yolo\\n\",\n",
    "    \"from ultralytics import YOLO\\n\",\n",
    "    \"from pycocotools.coco import COCO\\n\",\n",
    "    \"from pycocotools.cocoeval import COCOeval\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import matplotlib.patches as patches\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"d42bb5d3\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:56.677403500Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:56.656929500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 한글 폰트 자동 설정 (Windows + macOS 혼용 기준)\\n\",\n",
    "    \"# - Windows: Malgun Gothic(맑은 고딕)\\n\",\n",
    "    \"# - macOS: AppleGothic\\n\",\n",
    "    \"# - (fallback) NanumGothic / Noto Sans KR 계열\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"import platform\\n\",\n",
    "    \"import matplotlib as mpl\\n\",\n",
    "    \"\\n\",\n",
    "    \"def set_korean_font(verbose=True):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        from matplotlib import font_manager\\n\",\n",
    "    \"        available = {f.name for f in font_manager.fontManager.ttflist}\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        available = set()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    sysname = platform.system().lower()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if \\\"windows\\\" in sysname:\\n\",\n",
    "    \"        candidates = [\\\"Malgun Gothic\\\", \\\"맑은 고딕\\\", \\\"NanumGothic\\\", \\\"Noto Sans KR\\\"]\\n\",\n",
    "    \"    elif \\\"darwin\\\" in sysname or \\\"mac\\\" in sysname:\\n\",\n",
    "    \"        candidates = [\\\"AppleGothic\\\", \\\"NanumGothic\\\", \\\"Noto Sans KR\\\", \\\"Noto Sans CJK KR\\\"]\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        candidates = [\\\"NanumGothic\\\", \\\"Noto Sans CJK KR\\\", \\\"Noto Sans KR\\\", \\\"DejaVu Sans\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    chosen = None\\n\",\n",
    "    \"    for name in candidates:\\n\",\n",
    "    \"        # available이 비어있으면(폰트 스캔 실패) 일단 첫 후보를 적용 시도\\n\",\n",
    "    \"        if not available or name in available:\\n\",\n",
    "    \"            chosen = name\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if chosen:\\n\",\n",
    "    \"        mpl.rcParams[\\\"font.family\\\"] = chosen\\n\",\n",
    "    \"    mpl.rcParams[\\\"axes.unicode_minus\\\"] = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if verbose:\\n\",\n",
    "    \"        print(\\\"OS:\\\", platform.system())\\n\",\n",
    "    \"        print(\\\"✅ Matplotlib font:\\\", chosen)\\n\",\n",
    "    \"        if available and chosen not in available:\\n\",\n",
    "    \"            print(\\\"ℹ️ 선택된 폰트를 시스템에서 찾지 못했습니다. (그래도 렌더링은 될 수 있습니다)\\\")\\n\",\n",
    "    \"            print(\\\"   - Windows: '맑은 고딕' 설치 여부 확인\\\")\\n\",\n",
    "    \"            print(\\\"   - macOS: 기본 포함되는 AppleGothic 사용 권장\\\")\\n\",\n",
    "    \"    return chosen\\n\",\n",
    "    \"\\n\",\n",
    "    \"_ = set_korean_font(verbose=True)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"OS: Windows\\n\",\n",
    "      \"✅ Matplotlib font: Malgun Gothic\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"2e33d6a7\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:56.706354500Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:56.680405400Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 0) 설정\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"cfg = CFG()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (전역) Optuna 이후 최종 가중치 경로 (7-1 셀에서 설정)\\n\",\n",
    "    \"FINAL_WEIGHTS = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"cfg.force_apply_gci_remap = False  # (호환) 과거 로컬 라벨을 GCI로 치환할 때만 True\\n\",\n",
    "    \"\\n\",\n",
    "    \"cfg.test_image_id_mode = \\\"digits\\\"\\n\",\n",
    "    \"# 데이터 경로 (요청하신 경로)\\n\",\n",
    "    \"cfg.train_img_dir = \\\"data/train_images\\\"\\n\",\n",
    "    \"cfg.train_ann_dir = \\\"data/train_annotations\\\"\\n\",\n",
    "    \"cfg.test_img_dir  = \\\"data/test_images\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 출력 경로\\n\",\n",
    "    \"cfg.yolo_dataset_dir = \\\"yolo_pill_ds\\\"\\n\",\n",
    "    \"cfg.export_dir = \\\"exports_pill\\\"\\n\",\n",
    "    \"cfg.work_dir = \\\"runs_pill\\\"\\n\",\n",
    "    \"cfg.baseline_name = \\\"baseline\\\"\\n\",\n",
    "    \"cfg.optuna_subdir = \\\"optuna\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# (추가) Global Category Index(GCI) 경로\\n\",\n",
    "    \"# - gci_generator.py로 생성한 global_category_index.json을 사용하면\\n\",\n",
    "    \"#   YOLO class index <-> 원본 category_id(dl_idx) 매핑이 일관되게 유지됩니다.\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"cfg.gci_output_dir = \\\"global_category_index\\\"\\n\",\n",
    "    \"cfg.gci_json_path  = str(Path(cfg.gci_output_dir) / \\\"global_category_index.json\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (옵션) 추가 어노테이션(외부 데이터)을 임시로 넣을 폴더\\n\",\n",
    "    \"# - 여기에 COCO 단일 JSON들을 넣어두면 GCI 생성에 함께 반영됩니다.\\n\",\n",
    "    \"cfg.extra_ann_dir  = \\\"data/extra_annotations_tmp\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (옵션) GCI 생성 시 extra_ann_dir를 포함할지 (기본: False)\\n\",\n",
    "    \"cfg.gci_include_extra = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (옵션) GCI를 쓰더라도 'train split'에 등장하는 category만 사용해 nc/names를 줄일지\\n\",\n",
    "    \"cfg.gci_use_train_subset = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# (추가) local/global CSV 기반 GCI 보정 옵션\\n\",\n",
    "    \"# - local_categories.csv: 원본(로컬) 56개 라벨 목록\\n\",\n",
    "    \"# - global_category_index.csv: 전체(GCI) 매핑 테이블\\n\",\n",
    "    \"# - 로컬 라벨은 GCI에서 동일 name이 2개(연속 ID)로 중복되는 경우가 많아,\\n\",\n",
    "    \"#   'min(category_id)+1'을 로컬 category_id로 사용합니다.\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"cfg.local_categories_csv = \\\"local_categories.csv\\\"\\n\",\n",
    "    \"cfg.global_category_index_csv = \\\"global_category_index.csv\\\"\\n\",\n",
    "    \"cfg.use_local_gci_min_plus1 = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"set_seed(cfg.seed)\\n\",\n",
    "    \"print(cfg)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# (옵션) 모델 후보/증강/불균형 보정 설정\\n\",\n",
    "    \"# - 필요 없으면 주석 처리해도 됩니다.\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# ✅ YOLO 버전/크기 후보(원하는 것만 남기세요)\\n\",\n",
    "    \"# cfg.model_candidates = [\\\"yolov8n.pt\\\", \\\"yolov8s.pt\\\", \\\"yolov9c.pt\\\", \\\"yolov10n.pt\\\", \\\"yolo11n.pt\\\"]\\n\",\n",
    "    \"# cfg.base_model = cfg.model_candidates[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ✅ 색상 증강 비활성화(권장)\\n\",\n",
    "    \"cfg.hsv_h = 0.0\\n\",\n",
    "    \"cfg.hsv_s = 0.0\\n\",\n",
    "    \"cfg.hsv_v = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ✅ affine 중심 증강(필요하면 조절)\\n\",\n",
    "    \"# cfg.degrees = 10.0\\n\",\n",
    "    \"# cfg.translate = 0.10\\n\",\n",
    "    \"# cfg.scale = 0.20\\n\",\n",
    "    \"# cfg.shear = 2.0\\n\",\n",
    "    \"# cfg.perspective = 0.0005\\n\",\n",
    "    \"# cfg.fliplr = 0.5\\n\",\n",
    "    \"# cfg.flipud = 0.0\\n\",\n",
    "    \"# cfg.mosaic = 1.0\\n\",\n",
    "    \"# cfg.mixup = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ✅ 클래스 불균형 보정(옵션): train.txt에 일부 이미지를 \\\"추가로\\\" 반복 샘플링\\n\",\n",
    "    \"cfg.balance_enable = True\\n\",\n",
    "    \"cfg.balance_extra_ratio = 0.0# 전체 train 이미지 수의 50%만큼 추가로 더 뽑아서 train.txt에 append\\n\",\n",
    "    \"cfg.balance_power = 15.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ✅ 도메인 제약: 이미지당 최대 알약 수(최대 4)\\n\",\n",
    "    \"# - 제출 CSV 및 COCO 평가에서 score 상위 N개만 사용합니다.\\n\",\n",
    "    \"cfg.max_det_per_image = 4\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ✅ 제출용 score 임계값(필요 시 조절): 이 값보다 낮은 예측은 제출 CSV에서 제외\\n\",\n",
    "    \"cfg.submit_conf = cfg.conf\\n\",\n",
    "    \"# (옵션) YOLO 내부 후보 박스 상한(디버깅용)\\n\",\n",
    "    \"# cfg.max_det = 300\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"CFG()\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
