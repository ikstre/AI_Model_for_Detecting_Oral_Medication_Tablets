    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"db3d2139\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1) Load annotations (IDs preserved)\\n\",\n",
    "    \"\\n\",\n",
    "    \"어노테이션 규칙(사용자 설명 반영):\\n\",\n",
    "    \"- image_id: JSON 내부의 `images[].id` 사용 (파일명 기반 고유 ID가 이미 부여됨)\\n\",\n",
    "    \"- category_id: 각 JSON의 `images[0].dl_idx` (정수) 기반, 또는 `annotations[].category_id`가 있으면 그 값을 우선\\n\",\n",
    "    \"- annotation_id: `annotations[].id` 그대로 사용 (단, bbox 존재+유효일 때만)\\n\",\n",
    "    \"\\n\",\n",
    "    \"추가:\\n\",\n",
    "    \"- ID 충돌이 있으면 **데이터를 바꾸지 않고** 충돌 항목을 스킵하고 리포트합니다.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"1c7f7b67\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:56.928800700Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:56.708862100Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 1) COCO JSON 로드/병합 + 유효 bbox만 유지 (ID는 그대로)\\n\",\n",
    "    \"# - annotations는 \\\"bbox 존재\\\" + \\\"길이 4\\\"만 통과\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"\\n\",\n",
    "    \"json_paths = collect_json_files(cfg.train_ann_dir)\\n\",\n",
    "    \"print(\\\"num json files:\\\", len(json_paths))\\n\",\n",
    "    \"\\n\",\n",
    "    \"coco = merge_coco_from_many_json(json_paths)\\n\",\n",
    "    \"sanitize_coco_inplace(coco)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"images:\\\", len(coco.get(\\\"images\\\", [])))\\n\",\n",
    "    \"print(\\\"annotations(valid):\\\", len(coco.get(\\\"annotations\\\", [])))\\n\",\n",
    "    \"print(\\\"categories:\\\", len(coco.get(\\\"categories\\\", [])))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 호환용 별칭 (이전 버전 코드에서 coco_all을 쓰는 경우)\\n\",\n",
    "    \"coco_all = coco\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"num json files: 771\\n\",\n",
    "      \"images: 232\\n\",\n",
    "      \"annotations(valid): 771\\n\",\n",
    "      \"categories: 56\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"1d1c6f157a23a1\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1.5) Global Category Index(GCI) 생성/로드\\n\",\n",
    "    \"\\n\",\n",
    "    \"- category_id(=dl_idx)를 **global_index(0..K-1)**로 통일합니다.\\n\",\n",
    "    \"- YOLO 라벨(txt)에는 global_index를 class로 기록하고,\\n\",\n",
    "    \"- 제출 CSV에서는 global_index → category_id로 되돌려 `category_id`를 정확히 제출합니다.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"44e2927933019c12\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:56.973419400Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:56.930802200Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 1.5) Global Category Index(GCI) 생성/로드\\n\",\n",
    "    \"# - gci_generator.py 로직을 우선 사용하고, 실패하면(노트북/윈도우 병렬 이슈 등)\\n\",\n",
    "    \"#   단일 프로세스 \\\"light scan\\\"으로 fallback 합니다.\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import json, shutil\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_gci_light(annotation_dirs, out_dir):\\n\",\n",
    "    \"    # 단일 프로세스 스캔(Fallback)\\n\",\n",
    "    \"    # - cat_id: images[0].dl_idx 우선, 없으면 annotations[0].category_id 사용\\n\",\n",
    "    \"    # - cat_name: images[0].dl_name 사용(없으면 'Unknown')\\n\",\n",
    "    \"    out_dir = Path(out_dir)\\n\",\n",
    "    \"    out_dir.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    category_data = {}  # cat_id -> info\\n\",\n",
    "    \"    dataset_stats = {}\\n\",\n",
    "    \"    total_json = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for ann_dir in annotation_dirs:\\n\",\n",
    "    \"        ann_dir = Path(ann_dir)\\n\",\n",
    "    \"        if not ann_dir.exists():\\n\",\n",
    "    \"            print(\\\"[GCI] skip missing:\\\", ann_dir)\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ds_name = ann_dir.name\\n\",\n",
    "    \"        ds_total = 0\\n\",\n",
    "    \"        ds_counts = {}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for jf in ann_dir.rglob(\\\"*.json\\\"):\\n\",\n",
    "    \"            total_json += 1\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                with open(jf, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"                    data = json.load(f)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                img_meta = (data.get(\\\"images\\\") or [{}])[0]\\n\",\n",
    "    \"                ann_list = data.get(\\\"annotations\\\") or []\\n\",\n",
    "    \"                if not ann_list:\\n\",\n",
    "    \"                    continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"                dl_idx = img_meta.get(\\\"dl_idx\\\")\\n\",\n",
    "    \"                if dl_idx and str(dl_idx).strip():\\n\",\n",
    "    \"                    cat_id = int(dl_idx)\\n\",\n",
    "    \"                else:\\n\",\n",
    "    \"                    cat_id = ann_list[0].get(\\\"category_id\\\")\\n\",\n",
    "    \"                    if cat_id is None:\\n\",\n",
    "    \"                        continue\\n\",\n",
    "    \"                    cat_id = int(cat_id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                cat_name = img_meta.get(\\\"dl_name\\\", \\\"Unknown\\\")\\n\",\n",
    "    \"                k = len(ann_list)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            except Exception:\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if cat_id not in category_data:\\n\",\n",
    "    \"                category_data[cat_id] = {\\n\",\n",
    "    \"                    \\\"category_id\\\": cat_id,\\n\",\n",
    "    \"                    \\\"category_name\\\": cat_name,\\n\",\n",
    "    \"                    \\\"dl_idx\\\": str(dl_idx) if dl_idx else \\\"\\\",\\n\",\n",
    "    \"                    \\\"count\\\": 0,\\n\",\n",
    "    \"                    \\\"datasets\\\": {},\\n\",\n",
    "    \"                }\\n\",\n",
    "    \"\\n\",\n",
    "    \"            category_data[cat_id][\\\"count\\\"] += k\\n\",\n",
    "    \"            category_data[cat_id][\\\"datasets\\\"][ds_name] = category_data[cat_id][\\\"datasets\\\"].get(ds_name, 0) + k\\n\",\n",
    "    \"\\n\",\n",
    "    \"            ds_total += k\\n\",\n",
    "    \"            ds_counts[cat_id] = ds_counts.get(cat_id, 0) + k\\n\",\n",
    "    \"\\n\",\n",
    "    \"        dataset_stats[ds_name] = {\\n\",\n",
    "    \"            \\\"total_annotations\\\": ds_total,\\n\",\n",
    "    \"            \\\"unique_categories\\\": len(ds_counts),\\n\",\n",
    "    \"            \\\"category_counts\\\": ds_counts,\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    sorted_ids = sorted(category_data.keys())\\n\",\n",
    "    \"    index_to_id = {i: cid for i, cid in enumerate(sorted_ids)}\\n\",\n",
    "    \"    id_to_index = {cid: i for i, cid in index_to_id.items()}\\n\",\n",
    "    \"    total_ann = sum(category_data[cid][\\\"count\\\"] for cid in category_data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    json_data = {\\n\",\n",
    "    \"        \\\"metadata\\\": {\\n\",\n",
    "    \"            \\\"total_categories\\\": len(sorted_ids),\\n\",\n",
    "    \"            \\\"total_annotations\\\": total_ann,\\n\",\n",
    "    \"            \\\"total_datasets\\\": len(dataset_stats),\\n\",\n",
    "    \"            \\\"index_range\\\": f\\\"0-{len(sorted_ids)-1}\\\",\\n\",\n",
    "    \"            \\\"scanned_json_files\\\": total_json,\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        \\\"category_map\\\": {\\n\",\n",
    "    \"            str(cid): {**category_data[cid], \\\"datasets\\\": category_data[cid][\\\"datasets\\\"]}\\n\",\n",
    "    \"            for cid in category_data\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        \\\"index_to_id\\\": {str(k): v for k, v in index_to_id.items()},\\n\",\n",
    "    \"        \\\"id_to_index\\\": {str(k): v for k, v in id_to_index.items()},\\n\",\n",
    "    \"        \\\"dataset_stats\\\": dataset_stats,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    out_json = out_dir / \\\"global_category_index.json\\\"\\n\",\n",
    "    \"    with open(out_json, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"        json.dump(json_data, f, ensure_ascii=False, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # yolo_classes.txt (global_index 순서)\\n\",\n",
    "    \"    out_classes = out_dir / \\\"yolo_classes.txt\\\"\\n\",\n",
    "    \"    with open(out_classes, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"        for i in range(len(sorted_ids)):\\n\",\n",
    "    \"            cid = index_to_id[i]\\n\",\n",
    "    \"            f.write(category_data[cid][\\\"category_name\\\"] + \\\"\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # csv (요약)\\n\",\n",
    "    \"    rows = []\\n\",\n",
    "    \"    for i, cid in enumerate(sorted_ids):\\n\",\n",
    "    \"        info = category_data[cid]\\n\",\n",
    "    \"        rows.append({\\n\",\n",
    "    \"            \\\"category_id\\\": cid,\\n\",\n",
    "    \"            \\\"global_index\\\": i,\\n\",\n",
    "    \"            \\\"category_name\\\": info[\\\"category_name\\\"],\\n\",\n",
    "    \"            \\\"dl_idx\\\": info.get(\\\"dl_idx\\\", \\\"\\\"),\\n\",\n",
    "    \"            \\\"total_count\\\": info[\\\"count\\\"],\\n\",\n",
    "    \"        })\\n\",\n",
    "    \"    pd.DataFrame(rows).to_csv(out_dir / \\\"global_category_index.csv\\\", index=False, encoding=\\\"utf-8-sig\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"[GCI] light scan saved: {out_json} (K={len(sorted_ids)})\\\")\\n\",\n",
    "    \"    return str(out_json)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def ensure_gci(annotation_dirs, out_dir, force=False):\\n\",\n",
    "    \"    # gci_generator.py의 GCIBuilder를 우선 사용하고, 문제 생기면 build_gci_light로 fallback\\n\",\n",
    "    \"    out_dir = Path(out_dir)\\n\",\n",
    "    \"    out_dir.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"    out_json = out_dir / \\\"global_category_index.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if out_json.exists() and not force:\\n\",\n",
    "    \"        return str(out_json)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 1) gci_generator.py 시도\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        import importlib\\n\",\n",
    "    \"        gci_mod = importlib.import_module(\\\"gci_generator\\\")\\n\",\n",
    "    \"        if hasattr(gci_mod, \\\"GCIBuilder\\\"):\\n\",\n",
    "    \"            builder = gci_mod.GCIBuilder(annotation_dirs=annotation_dirs, output_dir=str(out_dir))\\n\",\n",
    "    \"            _ = builder.run()\\n\",\n",
    "    \"            if out_json.exists():\\n\",\n",
    "    \"                print(\\\"[GCI] generated via gci_generator.py:\\\", out_json)\\n\",\n",
    "    \"                return str(out_json)\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(\\\"[GCI] gci_generator.py 실패 -> fallback light scan:\\\", repr(e))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2) fallback\\n\",\n",
    "    \"    return build_gci_light(annotation_dirs, out_dir)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ---- annotation_dirs 구성: train_annotations만 (요청: train annotation 기반) ----\\n\",\n",
    "    \"ann_dirs = [str(Path(cfg.train_ann_dir))]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (옵션) extra annotations를 GCI에 함께 반영할지\\n\",\n",
    "    \"extra_ann_dir = Path(getattr(cfg, \\\"extra_ann_dir\\\", \\\"data/extra_annotations_tmp\\\"))\\n\",\n",
    "    \"if bool(getattr(cfg, \\\"gci_include_extra\\\", False)) and extra_ann_dir.exists():\\n\",\n",
    "    \"    ann_dirs.append(str(extra_ann_dir))\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # 기본은 train_only\\n\",\n",
    "    \"    if extra_ann_dir.exists():\\n\",\n",
    "    \"        print(\\\"[GCI] extra_ann_dir exists but excluded (cfg.gci_include_extra=False):\\\", extra_ann_dir)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"[GCI] extra_ann_dir not found (ok):\\\", extra_ann_dir)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ---- 생성/로드 ----\\n\",\n",
    "    \"\\n\",\n",
    "    \"gci_json_path = ensure_gci(ann_dirs, getattr(cfg, \\\"gci_output_dir\\\", \\\"global_category_index\\\"), force=False)\\n\",\n",
    "    \"cfg.gci_json_path = gci_json_path\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ---- export_dir에도 복사(제출 CSV 셀에서 찾기 쉽게) ----\\n\",\n",
    "    \"export_dir = Path(getattr(cfg, \\\"export_dir\\\", \\\"exports_pill\\\"))\\n\",\n",
    "    \"export_dir.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    shutil.copy2(gci_json_path, export_dir / \\\"global_category_index.json\\\")\\n\",\n",
    "    \"    print(\\\"[GCI] copied to export_dir:\\\", export_dir / \\\"global_category_index.json\\\")\\n\",\n",
    "    \"except Exception as e:\\n\",\n",
    "    \"    print(\\\"[GCI] copy to export_dir failed:\\\", e)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ---- 요약 ----\\n\",\n",
    "    \"with open(gci_json_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"    _gci = json.load(f)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"[GCI] total_categories:\\\", _gci[\\\"metadata\\\"][\\\"total_categories\\\"])\\n\",\n",
    "    \"print(\\\"[GCI] total_annotations:\\\", _gci[\\\"metadata\\\"][\\\"total_annotations\\\"])\\n\",\n",
    "    \"print(\\\"[GCI] scanned_json_files:\\\", _gci[\\\"metadata\\\"].get(\\\"scanned_json_files\\\", \\\"n/a\\\"))\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"[GCI] extra_ann_dir not found (ok): data\\\\extra_annotations_tmp\\n\",\n",
    "      \"[GCI] copied to export_dir: exports_pill\\\\global_category_index.json\\n\",\n",
    "      \"[GCI] total_categories: 4565\\n\",\n",
    "      \"[GCI] total_annotations: 2658679\\n\",\n",
    "      \"[GCI] scanned_json_files: n/a\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 5\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"a7b981db\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2) Debug: 한 장 이미지에 bbox 올려보기\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"c30c717a\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:57.176898500Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:56.974919Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"def resolve_train_image_path(train_img_dir, file_name):\\n\",\n",
    "    \"    p = Path(file_name)\\n\",\n",
    "    \"    if p.exists():\\n\",\n",
    "    \"        return p\\n\",\n",
    "    \"    cand = Path(train_img_dir) / p.name\\n\",\n",
    "    \"    if cand.exists():\\n\",\n",
    "    \"        return cand\\n\",\n",
    "    \"    stem = p.stem\\n\",\n",
    "    \"    for ext in [\\\".png\\\",\\\".jpg\\\",\\\".jpeg\\\",\\\".bmp\\\",\\\".webp\\\"]:\\n\",\n",
    "    \"        cand2 = Path(train_img_dir) / (stem + ext)\\n\",\n",
    "    \"        if cand2.exists():\\n\",\n",
    "    \"            return cand2\\n\",\n",
    "    \"    return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_image_with_bboxes(cfg, coco, image_id, max_show=50):\\n\",\n",
    "    \"    img = next((im for im in coco[\\\"images\\\"] if im[\\\"id\\\"] == image_id), None)\\n\",\n",
    "    \"    if img is None:\\n\",\n",
    "    \"        print(\\\"image not found:\\\", image_id); return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    path = resolve_train_image_path(cfg.train_img_dir, img[\\\"file_name\\\"])\\n\",\n",
    "    \"    if path is None:\\n\",\n",
    "    \"        print(\\\"image file missing:\\\", img[\\\"file_name\\\"]); return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    import matplotlib.image as mpimg\\n\",\n",
    "    \"    imarr = mpimg.imread(str(path))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    fig, ax = plt.subplots(1,1, figsize=(10,8))\\n\",\n",
    "    \"    ax.imshow(imarr)\\n\",\n",
    "    \"    ax.set_title(f\\\"id={image_id} | {Path(img['file_name']).name}\\\")\\n\",\n",
    "    \"    ax.axis(\\\"off\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    anns = [a for a in coco[\\\"annotations\\\"] if a[\\\"image_id\\\"] == image_id][:max_show]\\n\",\n",
    "    \"    for a in anns:\\n\",\n",
    "    \"        x,y,w,h = a[\\\"bbox\\\"]\\n\",\n",
    "    \"        rect = patches.Rectangle((x,y), w, h, linewidth=2, edgecolor='r', facecolor='none')\\n\",\n",
    "    \"        ax.add_patch(rect)\\n\",\n",
    "    \"        ax.text(x, y, str(a[\\\"category_id\\\"]), color=\\\"yellow\\\", fontsize=10, bbox=dict(facecolor=\\\"black\\\", alpha=0.5, pad=1))\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 랜덤 1장 확인\\n\",\n",
    "    \"rand_img_id = random.choice([im[\\\"id\\\"] for im in coco[\\\"images\\\"]])\\n\",\n",
    "    \"plot_image_with_bboxes(cfg, coco, rand_img_id)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 1000x800 with 1 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\",\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     }\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 6\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"6dbffaf5\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3) Split train/val (image 단위)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"d8f58462\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:57.196957100Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:57.179407800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 2) Train / Val 분리\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"train_coco, val_coco = split_coco_by_image(coco, val_ratio=cfg.val_ratio, seed=cfg.seed)\\n\",\n",
    "    \"print(\\\"train images:\\\", len(train_coco[\\\"images\\\"]), \\\"train anns:\\\", len(train_coco[\\\"annotations\\\"]))\\n\",\n",
    "    \"print(\\\"val images:\\\", len(val_coco[\\\"images\\\"]), \\\"val anns:\\\", len(val_coco[\\\"annotations\\\"]))\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"train images: 186 train anns: 618\\n\",\n",
    "      \"val images: 46 val anns: 153\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 7\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"4fb86dcd\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4) YOLO export (category_id는 매핑만 사용)\\n\",\n",
    "    \"\\n\",\n",
    "    \"- 원본 `category_id`는 그대로 유지해야 하므로,\\n\",\n",
    "    \"  - YOLO 학습용 라벨에는 `yolo_cls(0..nc-1)`를 사용하고,\\n\",\n",
    "    \"  - `cat_mapping.json`에 원본 category_id ↔ yolo_cls를 저장합니다.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"158c67f3\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-05T01:55:57.315908700Z\",\n",
    "     \"start_time\": \"2026-02-05T01:55:57.198967300Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 3) category_id <-> yolo cls 매핑 (LOCAL-GCI min+1 우선)\\n\",\n",
    "    \"#\\n\",\n",
    "    \"# 요구사항 정리\\n\",\n",
    "    \"# - local(원본) 라벨만 사용 (local_categories.csv: 56개)\\n\",\n",
    "    \"# - GCI(global)에는 동일 name이 2개로 중복되는 경우가 많음\\n\",\n",
    "    \"#   → 중복 시 id가 작은 것(min)을 기준으로 하고, +1 한 값을 '로컬 category_id'로 사용\\n\",\n",
    "    \"# - 학습/예측에서 YOLO cls는 0..(nc-1) (local 56개로 재인덱싱)\\n\",\n",
    "    \"# - COCO train annotation에 들어있는 category_id가 (min) 또는 (min+1) 어느 쪽이든\\n\",\n",
    "    \"#   동일 cls로 매핑되도록 catid_to_yolo에 alias를 함께 등록\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 1) local 라벨 로드\\n\",\n",
    "    \"local_csv = Path(getattr(cfg, \\\"local_categories_csv\\\", \\\"local_categories.csv\\\"))\\n\",\n",
    "    \"if not local_csv.exists():\\n\",\n",
    "    \"    raise FileNotFoundError(f\\\"local_categories.csv not found: {local_csv.resolve()}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"local_df = pd.read_csv(local_csv)\\n\",\n",
    "    \"local_df[\\\"category_id\\\"] = local_df[\\\"category_id\\\"].astype(int)\\n\",\n",
    "    \"local_df[\\\"category_name\\\"] = local_df[\\\"category_name\\\"].astype(str)\\n\",\n",
    "    \"\\n\",\n",
    "    \"local_names = local_df[\\\"category_name\\\"].tolist()\\n\",\n",
    "    \"local_expected_id_by_name = dict(zip(local_df[\\\"category_name\\\"], local_df[\\\"category_id\\\"]))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 2) global(GCI) 테이블 로드 (CSV 우선, 없으면 gci_json의 category_map fallback)\\n\",\n",
    "    \"gci_csv_candidates = [\\n\",\n",
    "    \"    Path(getattr(cfg, \\\"global_category_index_csv\\\", \\\"\\\")),\\n\",\n",
    "    \"    Path(getattr(cfg, \\\"gci_output_dir\\\", \\\"global_category_index\\\")) / \\\"global_category_index.csv\\\",\\n\",\n",
    "    \"    Path(\\\"global_category_index.csv\\\"),\\n\",\n",
    "    \"]\\n\",\n",
    "    \"gci_csv_path = next((p for p in gci_csv_candidates if p and str(p) and Path(p).exists()), None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"global_df = None\\n\",\n",
    "    \"if gci_csv_path is not None:\\n\",\n",
    "    \"    global_df = pd.read_csv(gci_csv_path)\\n\",\n",
    "    \"    global_df[\\\"category_id\\\"] = global_df[\\\"category_id\\\"].astype(int)\\n\",\n",
    "    \"    global_df[\\\"category_name\\\"] = global_df[\\\"category_name\\\"].astype(str)\\n\",\n",
    "    \"    print(\\\"[Mapping] loaded global_category_index.csv ->\\\", Path(gci_csv_path).resolve())\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    gci_path = Path(getattr(cfg, \\\"gci_json_path\\\", \\\"\\\"))\\n\",\n",
    "    \"    if gci_path.exists():\\n\",\n",
    "    \"        with open(gci_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"            gci = json.load(f)\\n\",\n",
    "    \"        cat_map = gci.get(\\\"category_map\\\", {})  # str(cat_id) -> {\\\"category_name\\\": ...}\\n\",\n",
    "    \"        rows = []\\n\",\n",
    "    \"        for k, v in cat_map.items():\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                cid = int(k)\\n\",\n",
    "    \"            except Exception:\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"            nm = str(v.get(\\\"category_name\\\", cid))\\n\",\n",
    "    \"            rows.append({\\\"category_id\\\": cid, \\\"category_name\\\": nm})\\n\",\n",
    "    \"        global_df = pd.DataFrame(rows)\\n\",\n",
    "    \"        print(\\\"[Mapping] loaded category_map from gci_json ->\\\", gci_path.resolve(), \\\"| rows:\\\", len(global_df))\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        raise FileNotFoundError(\\\"global_category_index.csv and gci_json are both missing. Need at least one.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 3) local 이름만 GCI에서 추출 + (중복 시) min(category_id)+1을 로컬 category_id로 결정\\n\",\n",
    "    \"#    그리고 (min_id)도 alias로 함께 등록해서, annotation이 어느 쪽을 쓰더라도 학습/평가가 일관되게 되도록 함.\\n\",\n",
    "    \"use_min_plus1 = bool(getattr(cfg, \\\"use_local_gci_min_plus1\\\", True))\\n\",\n",
    "    \"\\n\",\n",
    "    \"yolo_to_catid = {}\\n\",\n",
    "    \"catid_to_yolo = {}\\n\",\n",
    "    \"catid_to_name = {}\\n\",\n",
    "    \"alias_debug = []  # (name, min_id, chosen_local_id, expected_local_id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i, name in enumerate(local_names):\\n\",\n",
    "    \"    sub = global_df[global_df[\\\"category_name\\\"] == name]\\n\",\n",
    "    \"    if len(sub) == 0:\\n\",\n",
    "    \"        # GCI에 없으면 local_df 기준으로만 사용 (드문 케이스)\\n\",\n",
    "    \"        chosen_local_id = int(local_expected_id_by_name[name])\\n\",\n",
    "    \"        min_id = None\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        min_id = int(sub[\\\"category_id\\\"].min())\\n\",\n",
    "    \"        if use_min_plus1:\\n\",\n",
    "    \"            chosen_local_id = min_id + 1\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            chosen_local_id = int(sub[\\\"category_id\\\"].max())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    expected = int(local_expected_id_by_name[name])\\n\",\n",
    "    \"    if chosen_local_id != expected:\\n\",\n",
    "    \"        # 안전장치: 기대(local_categories.csv)와 다르면 local_df를 우선으로 사용\\n\",\n",
    "    \"        alias_debug.append((name, min_id, chosen_local_id, expected, \\\"OVERRIDE->expected\\\"))\\n\",\n",
    "    \"        chosen_local_id = expected\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        alias_debug.append((name, min_id, chosen_local_id, expected, \\\"OK\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # YOLO cls(i) -> 제출용 category_id(로컬)\\n\",\n",
    "    \"    yolo_to_catid[i] = chosen_local_id\\n\",\n",
    "    \"    catid_to_name[chosen_local_id] = name\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # COCO annotation category_id -> YOLO cls(i)\\n\",\n",
    "    \"    # - 로컬 ID(=chosen_local_id) 매핑\\n\",\n",
    "    \"    catid_to_yolo[chosen_local_id] = i\\n\",\n",
    "    \"    # - alias: min_id도 같은 cls로 매핑 (있고, 로컬과 다르면)\\n\",\n",
    "    \"    if min_id is not None and int(min_id) != int(chosen_local_id):\\n\",\n",
    "    \"        catid_to_yolo[int(min_id)] = i\\n\",\n",
    "    \"        catid_to_name[int(min_id)] = name  # 평가/디버그용\\n\",\n",
    "    \"\\n\",\n",
    "    \"names = local_names\\n\",\n",
    "    \"YOLO_INDEX_IS_SUBSET = True\\n\",\n",
    "    \"SUBMIT_INDEX_TO_ID = {int(k): int(v) for k, v in yolo_to_catid.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"[Mapping] LOCAL subset enabled | nc={len(names)} | use_min_plus1={use_min_plus1}\\\")\\n\",\n",
    "    \"print(\\\"[Mapping] sample(alias_debug first 5):\\\")\\n\",\n",
    "    \"for r in alias_debug[:5]:\\n\",\n",
    "    \"    print(\\\"  -\\\", r)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (옵션) 매핑 파일 저장: 제출/추론만 따로 돌려도 동일 결과 보장\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    out_root = Path(getattr(cfg, 'yolo_dataset_dir', 'yolo_pill_ds'))\\n\",\n",
    "    \"    out_root.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with open(out_root / 'submit_index_to_id.json', 'w', encoding='utf-8') as f:\\n\",\n",
    "    \"        json.dump(SUBMIT_INDEX_TO_ID, f, ensure_ascii=False, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with open(out_root / 'catid_to_yolo.json', 'w', encoding='utf-8') as f:\\n\",\n",
    "    \"        json.dump({str(k): int(v) for k, v in catid_to_yolo.items()}, f, ensure_ascii=False, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with open(out_root / 'catid_to_name.json', 'w', encoding='utf-8') as f:\\n\",\n",
    "    \"        json.dump({str(k): v for k, v in catid_to_name.items()}, f, ensure_ascii=False, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # local-only gci json(간단 버전)\\n\",\n",
    "    \"    gci_local = {\\n\",\n",
    "    \"        \\\"id_to_index\\\": {str(v): int(k) for k, v in SUBMIT_INDEX_TO_ID.items()},  # local cat_id -> subset idx\\n\",\n",
    "    \"        \\\"index_to_id\\\": {str(k): int(v) for k, v in SUBMIT_INDEX_TO_ID.items()},  # subset idx -> local cat_id\\n\",\n",
    "    \"        \\\"category_map\\\": {str(v): {\\\"category_id\\\": int(v), \\\"category_name\\\": names[k]} for k, v in SUBMIT_INDEX_TO_ID.items()},\\n\",\n",
    "    \"        \\\"n_categories\\\": len(names),\\n\",\n",
    "    \"        \\\"note\\\": \\\"local subset extracted from GCI; duplicates resolved by min(category_id)+1 (then validated vs local_categories.csv)\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    gci_out = Path(getattr(cfg, \\\"gci_output_dir\\\", \\\"global_category_index\\\"))\\n\",\n",
    "    \"    gci_out.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"    with open(gci_out / \\\"gci_local_subset.json\\\", \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"        json.dump(gci_local, f, ensure_ascii=False, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\\"[Mapping] saved mappings ->\\\", out_root.resolve())\\n\",\n",
    "    \"    print(\\\"[Mapping] saved gci_local_subset.json ->\\\", (gci_out / \\\"gci_local_subset.json\\\").resolve())\\n\",\n",
    "    \"except Exception as e:\\n\",\n",
    "    \"    print(\\\"[Mapping] mapping save failed:\\\", e)\\n\"\n",
    "   ],\n",
