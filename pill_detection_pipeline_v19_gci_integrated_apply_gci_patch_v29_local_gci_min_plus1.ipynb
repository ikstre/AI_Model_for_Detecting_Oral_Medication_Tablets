    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"8fb6d99a\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8) Inference on test & make Kaggle submission CSV\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"b271addf\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 8) 테스트 추론 후 제출 CSV 생성 (csv_generator.py 로직 병합 버전)\\n\",\n",
    "    \"# - stream + chunking으로 빠르게 추론\\n\",\n",
    "    \"# - 파일명에서 image_id 추출(숫자) + image_id/score 정렬\\n\",\n",
    "    \"# - (가능하면) global_category_index.json 사용, 없으면 yolo_to_catid로 대체\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"import json, csv, re\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"IMG_EXTS = {\\\".jpg\\\", \\\".jpeg\\\", \\\".png\\\", \\\".bmp\\\", \\\".webp\\\", \\\".tif\\\", \\\".tiff\\\"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"def list_images(img_dir: Path):\\n\",\n",
    "    \"    files = [p for p in Path(img_dir).rglob(\\\"*\\\") if p.suffix.lower() in IMG_EXTS]\\n\",\n",
    "    \"    files.sort(key=lambda p: str(p).lower())\\n\",\n",
    "    \"    return files\\n\",\n",
    "    \"\\n\",\n",
    "    \"def xyxy_to_xywh(x1, y1, x2, y2):\\n\",\n",
    "    \"    return x1, y1, (x2 - x1), (y2 - y1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_index_to_id(gci_json_path: str):\\n\",\n",
    "    \"    with open(gci_json_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"        gci = json.load(f)\\n\",\n",
    "    \"    idx2id_raw = gci[\\\"index_to_id\\\"]\\n\",\n",
    "    \"    return {int(k): int(v) for k, v in idx2id_raw.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"def chunked(lst, n):\\n\",\n",
    "    \"    for i in range(0, len(lst), n):\\n\",\n",
    "    \"        yield lst[i:i+n]\\n\",\n",
    "    \"\\n\",\n",
    "    \"def extract_image_id_from_filename(p: Path) -> int:\\n\",\n",
    "    \"    # 파일명이 '000123.jpg' 같은 형태면 그대로 사용\\n\",\n",
    "    \"    stem = p.stem\\n\",\n",
    "    \"    if stem.isdigit():\\n\",\n",
    "    \"        return int(stem)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 숫자 그룹이 여러 개면 마지막 그룹을 사용(필요 시 nums[0]으로 변경)\\n\",\n",
    "    \"    nums = re.findall(r\\\"\\\\d+\\\", stem)\\n\",\n",
    "    \"    if not nums:\\n\",\n",
    "    \"        raise ValueError(f\\\"파일명에서 숫자를 찾을 수 없음: {p.name}\\\")\\n\",\n",
    "    \"    return int(nums[-1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"def resolve_index_to_id():\\n\",\n",
    "    \"    # (요청) train subset class를 사용하는 경우(=nc가 줄어든 경우),\\n\",\n",
    "    \"    # 모델의 cls는 'subset index'이므로 notebook에서 만든 매핑을 최우선으로 사용합니다.\\n\",\n",
    "    \"    if bool(getattr(cfg, \\\"gci_use_train_subset\\\", False)):\\n\",\n",
    "    \"        if \\\"SUBMIT_INDEX_TO_ID\\\" in globals():\\n\",\n",
    "    \"            print(\\\"[Mapping] use SUBMIT_INDEX_TO_ID (train subset)\\\")\\n\",\n",
    "    \"            return {int(k): int(v) for k, v in SUBMIT_INDEX_TO_ID.items()}\\n\",\n",
    "    \"        if \\\"yolo_to_catid\\\" in globals():\\n\",\n",
    "    \"            print(\\\"[Mapping] use yolo_to_catid (train subset)\\\")\\n\",\n",
    "    \"            return {int(k): int(v) for k, v in yolo_to_catid.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 1) exports/ 하위에 global_category_index.json이 있으면 우선 사용\\n\",\n",
    "    \"    candidates = [\\n\",\n",
    "    \"        # 0) cfg.gci_json_path (가장 우선)\\n\",\n",
    "    \"        Path(getattr(cfg, \\\"gci_json_path\\\", \\\"\\\")),\\n\",\n",
    "    \"        # 1) exports/ 하위\\n\",\n",
    "    \"        Path(getattr(cfg, \\\"export_dir\\\", \\\"exports_pill\\\")) / \\\"global_category_index.json\\\",\\n\",\n",
    "    \"        Path(getattr(cfg, \\\"export_dir\\\", \\\"exports_pill\\\")) / \\\"global_category_index\\\" / \\\"global_category_index.json\\\",\\n\",\n",
    "    \"        # 2) 현재 폴더\\n\",\n",
    "    \"        Path(\\\"global_category_index.json\\\"),\\n\",\n",
    "    \"        Path(\\\"global_category_index\\\") / \\\"global_category_index.json\\\",]\\n\",\n",
    "    \"    for p in candidates:\\n\",\n",
    "    \"        if p is None:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        p = Path(p)\\n\",\n",
    "    \"        if str(p) in ('', '.'):\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        if p.exists():\\n\",\n",
    "    \"            print(\\\"[Mapping] use global_category_index:\\\", p)\\n\",\n",
    "    \"            return load_index_to_id(str(p))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2) 없으면 notebook에서 이미 만든 yolo_to_catid를 그대로 사용\\n\",\n",
    "    \"    if \\\"yolo_to_catid\\\" in globals():\\n\",\n",
    "    \"        print(\\\"[Mapping] use yolo_to_catid (fallback)\\\")\\n\",\n",
    "    \"        return {int(k): int(v) for k, v in yolo_to_catid.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    raise FileNotFoundError(\\\"global_category_index.json도 없고, yolo_to_catid도 없습니다. 매핑을 만들 수 없습니다.\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"c389aaf93fa419ae\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"def run_infer_to_csv(\\n\",\n",
    "    \"    weights_path: str,\\n\",\n",
    "    \"    test_img_dir: str,\\n\",\n",
    "    \"    out_csv_path: str,\\n\",\n",
    "    \"    index_to_id: dict,\\n\",\n",
    "    \"    imgsz: int = 512,\\n\",\n",
    "    \"    conf: float = 0.001,\\n\",\n",
    "    \"    iou: float = 0.7,\\n\",\n",
    "    \"    max_det_per_image: int = 4,\\n\",\n",
    "    \"    device=0,\\n\",\n",
    "    \"    pred_batch: int = 4,\\n\",\n",
    "    \"    chunk_size: int = 200,\\n\",\n",
    "    \"    half: bool = True,\\n\",\n",
    "    \"    submit_conf=None,\\n\",\n",
    "    \"):\\n\",\n",
    "    \"    test_img_dir = Path(test_img_dir)\\n\",\n",
    "    \"    out_csv_path = Path(out_csv_path)\\n\",\n",
    "    \"    out_csv_path.parent.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    model = YOLO(weights_path)\\n\",\n",
    "    \"    img_files = list_images(test_img_dir)\\n\",\n",
    "    \"    if not img_files:\\n\",\n",
    "    \"        raise FileNotFoundError(f\\\"No images in: {test_img_dir}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # (디버그) 앞 50개 image_id 중복 체크\\n\",\n",
    "    \"    seen = set()\\n\",\n",
    "    \"    for p in img_files[:50]:\\n\",\n",
    "    \"        iid = extract_image_id_from_filename(p)\\n\",\n",
    "    \"        if iid in seen:\\n\",\n",
    "    \"            print(f\\\"⚠️ image_id 중복 가능성: {iid} (파일: {p.name})\\\")\\n\",\n",
    "    \"        seen.add(iid)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 제출 임계값(없으면 conf와 분리 가능)\\n\",\n",
    "    \"    if submit_conf is None:\\n\",\n",
    "    \"        submit_conf = float(conf)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    ann_id = 1\\n\",\n",
    "    \"    total_det = 0\\n\",\n",
    "    \"    no_det = 0\\n\",\n",
    "    \"    no_det_after_thr = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with open(out_csv_path, \\\"w\\\", newline=\\\"\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"        writer = csv.writer(f)\\n\",\n",
    "    \"        writer.writerow([\\n\",\n",
    "    \"            \\\"annotation_id\\\", \\\"image_id\\\", \\\"category_id\\\",\\n\",\n",
    "    \"            \\\"bbox_x\\\", \\\"bbox_y\\\", \\\"bbox_w\\\", \\\"bbox_h\\\", \\\"score\\\"\\n\",\n",
    "    \"        ])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        pbar = tqdm(total=len(img_files), desc=\\\"Test inference\\\", leave=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for chunk in chunked(img_files, int(chunk_size)):\\n\",\n",
    "    \"            results_iter = model.predict(\\n\",\n",
    "    \"                source=[str(p) for p in chunk],\\n\",\n",
    "    \"                imgsz=int(imgsz),\\n\",\n",
    "    \"                conf=float(conf),\\n\",\n",
    "    \"                iou=float(iou),\\n\",\n",
    "    \"                device=device,\\n\",\n",
    "    \"                stream=True,\\n\",\n",
    "    \"                batch=int(pred_batch),\\n\",\n",
    "    \"                half=bool(half),\\n\",\n",
    "    \"                verbose=False,\\n\",\n",
    "    \"                max_det=int(max_det_per_image),\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"            for res in results_iter:\\n\",\n",
    "    \"                img_path = Path(res.path)\\n\",\n",
    "    \"                img_id = extract_image_id_from_filename(img_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if res.boxes is None or len(res.boxes) == 0:\\n\",\n",
    "    \"                    no_det += 1\\n\",\n",
    "    \"                    pbar.update(1)\\n\",\n",
    "    \"                    continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"                xyxy = res.boxes.xyxy.cpu().numpy()\\n\",\n",
    "    \"                confs = res.boxes.conf.cpu().numpy()\\n\",\n",
    "    \"                clss = res.boxes.cls.cpu().numpy().astype(int)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                order = confs.argsort()[::-1]\\n\",\n",
    "    \"                # 제출 score 임계값\\n\",\n",
    "    \"                order = order[confs[order] >= float(submit_conf)]\\n\",\n",
    "    \"                # 이미지당 최대 N개\\n\",\n",
    "    \"                order = order[:int(max_det_per_image)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if len(order) == 0:\\n\",\n",
    "    \"                    no_det_after_thr += 1\\n\",\n",
    "    \"                    pbar.update(1)\\n\",\n",
    "    \"                    continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for i in order:\\n\",\n",
    "    \"                    score = float(confs[i])\\n\",\n",
    "    \"                    global_index = int(clss[i])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if global_index not in index_to_id:\\n\",\n",
    "    \"                        continue\\n\",\n",
    "    \"                    cat_id = int(index_to_id[global_index])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    x1, y1, x2, y2 = xyxy[i]\\n\",\n",
    "    \"                    bx, by, bw, bh = xyxy_to_xywh(x1, y1, x2, y2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    # int 변환 + 유효성 체크\\n\",\n",
    "    \"                    bx, by, bw, bh = int(round(bx)), int(round(by)), int(round(bw)), int(round(bh))\\n\",\n",
    "    \"                    if bw <= 0 or bh <= 0:\\n\",\n",
    "    \"                        continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    writer.writerow([ann_id, img_id, cat_id, bx, by, bw, bh, round(score, 6)])\\n\",\n",
    "    \"                    ann_id += 1\\n\",\n",
    "    \"                    total_det += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"                pbar.update(1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        pbar.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # pandas로 정렬/검증(선택)\\n\",\n",
    "    \"    sub_df = pd.read_csv(out_csv_path)\\n\",\n",
    "    \"    if not sub_df.empty:\\n\",\n",
    "    \"        sub_df[\\\"image_id\\\"] = sub_df[\\\"image_id\\\"].astype(int)\\n\",\n",
    "    \"        sub_df[\\\"score\\\"] = sub_df[\\\"score\\\"].astype(float)\\n\",\n",
    "    \"        sub_df = sub_df.sort_values([\\\"image_id\\\", \\\"score\\\"], ascending=[True, False], kind=\\\"mergesort\\\").reset_index(drop=True)\\n\",\n",
    "    \"        # ✅ (안전) 채점 요구사항 대응: annotation_id를 \\\"최종 row 기준\\\"으로 1..N 재부여\\n\",\n",
    "    \"        sub_df[\\\"annotation_id\\\"] = range(1, len(sub_df) + 1)\\n\",\n",
    "    \"        sub_df[\\\"annotation_id\\\"] = sub_df[\\\"annotation_id\\\"].astype(int)\\n\",\n",
    "    \"        sub_df.to_csv(out_csv_path, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\\"✅ 완료\\\")\\n\",\n",
    "    \"    print(f\\\"- weights: {weights_path}\\\")\\n\",\n",
    "    \"    print(f\\\"- 저장: {out_csv_path}\\\")\\n\",\n",
    "    \"    print(f\\\"- 이미지: {len(img_files)}\\\")\\n\",\n",
    "    \"    print(f\\\"- 탐지없음(원본): {no_det}\\\")\\n\",\n",
    "    \"    print(f\\\"- 탐지없음(임계값 후): {no_det_after_thr}\\\")\\n\",\n",
    "    \"    print(f\\\"- 총 탐지(작성): {total_det}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return sub_df, str(out_csv_path)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"14aa651e58dd2964\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# 실행\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# 사용 weights 우선순위:\\n\",\n",
    "    \"# 1) Optuna 최종 재학습에서 저장한 cfg.final_weights (권장)\\n\",\n",
    "    \"# 2) (호환) FINAL_WEIGHTS 전역 변수\\n\",\n",
    "    \"# 3) baseline(best_pt)\\n\",\n",
    "    \"# 4) 그 외 model 내부 경로(버전별 상이)\\n\",\n",
    "    \"weights_path = getattr(cfg, \\\"final_weights\\\", None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if (not weights_path) and (\\\"FINAL_WEIGHTS\\\" in globals()) and (FINAL_WEIGHTS is not None):\\n\",\n",
    "    \"    weights_path = str(FINAL_WEIGHTS)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if (not weights_path) and (\\\"best_pt\\\" in globals()) and (best_pt is not None):\\n\",\n",
    "    \"    weights_path = str(best_pt)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if (not weights_path) or (str(weights_path) == \\\"None\\\"):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        weights_path = str(getattr(model, \\\"ckpt_path\\\", None) or getattr(model, \\\"model\\\", None))\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        weights_path = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"if (not weights_path) or (str(weights_path) == \\\"None\\\"):\\n\",\n",
    "    \"    raise RuntimeError(\\\"weights_path를 결정하지 못했습니다. Optuna 최종 재학습(7-1) 또는 baseline 학습(옵션)을 먼저 실행해 주세요.\\\")\\n\",\n",
    "    \"index_to_id = resolve_index_to_id()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 제출 파라미터\\n\",\n",
    "    \"out_csv_path = str(Path(getattr(cfg, \\\"export_dir\\\", \\\"exports_pill\\\")) / \\\"submission.csv\\\")\\n\",\n",
    "    \"submit_conf = float(getattr(cfg, \\\"submit_conf\\\", 0.1))      # 제출시 score threshold\\n\",\n",
    "    \"max_keep = int(getattr(cfg, \\\"max_det_per_image\\\", 4))       # 이미지당 최대 4개\\n\",\n",
    "    \"imgsz = int(getattr(cfg, \\\"imgsz\\\", 640))\\n\",\n",
    "    \"conf  = float(getattr(cfg, \\\"conf\\\", 0.001))\\n\",\n",
    "    \"iou   = float(getattr(cfg, \\\"iou\\\", 0.7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"sub_df, sub_path = run_infer_to_csv(\\n\",\n",
    "    \"    weights_path=weights_path,\\n\",\n",
    "    \"    test_img_dir=str(cfg.test_img_dir),\\n\",\n",
    "    \"    out_csv_path=out_csv_path,\\n\",\n",
    "    \"    index_to_id=index_to_id,\\n\",\n",
    "    \"    imgsz=imgsz,\\n\",\n",
    "    \"    conf=conf,\\n\",\n",
    "    \"    iou=iou,\\n\",\n",
    "    \"    max_det_per_image=max_keep,\\n\",\n",
    "    \"    device=getattr(cfg, \\\"device\\\", 0),\\n\",\n",
    "    \"    pred_batch=int(getattr(cfg, \\\"pred_batch\\\", 4)),\\n\",\n",
    "    \"    chunk_size=int(getattr(cfg, \\\"chunk_size\\\", 200)),\\n\",\n",
    "    \"    half=bool(getattr(cfg, \\\"half\\\", True)),\\n\",\n",
    "    \"    submit_conf=submit_conf,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"sub_df.head(), sub_path\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
