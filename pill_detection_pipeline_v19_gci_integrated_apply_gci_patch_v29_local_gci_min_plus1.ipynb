    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"0da9c7bb\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Optuna 실행 (Pruner 적용)\\n\",\n",
    "    \"# - sampler: TPE\\n\",\n",
    "    \"# - pruner: Hyperband (중간 성능 나쁜 trial은 조기 중단)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sampler = optuna.samplers.TPESampler(seed=int(getattr(cfg, \\\"seed\\\", 42)))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# max_resource는 optuna_epochs와 맞추는 게 자연스럽습니다.\\n\",\n",
    "    \"max_res = int(getattr(cfg, \\\"optuna_epochs\\\",30 ))\\n\",\n",
    "    \"pruner = optuna.pruners.HyperbandPruner(\\n\",\n",
    "    \"    min_resource=1,\\n\",\n",
    "    \"    max_resource=max_res,\\n\",\n",
    "    \"    reduction_factor=3\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"study = optuna.create_study(direction=\\\"maximize\\\", sampler=sampler, pruner=pruner)\\n\",\n",
    "    \"study.optimize(objective, n_trials=30, gc_after_trial=True, show_progress_bar=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"best_params:\\\", study.best_params)\\n\",\n",
    "    \"print(\\\"best_value :\\\", study.best_value)\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"a4c1f110214cfb24\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 7-1) Optuna best params로 \\\"최종 재학습\\\" (Optuna 이후 추가 학습)\\n\",\n",
    "    \"# - Optuna trial은 보통 짧은 epochs로 탐색용이므로,\\n\",\n",
    "    \"#   best_params로 cfg.epochs 만큼 다시 학습하여 최종 best.pt를 얻습니다.\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Optuna를 실행하지 않았거나(best_params 없음)인 경우를 대비\\n\",\n",
    "    \"if 'study' not in globals():\\n\",\n",
    "    \"    raise RuntimeError(\\\"Optuna study가 없습니다. 바로 위 Optuna 셀(7)을 먼저 실행해 주세요.\\\")\\n\",\n",
    "    \"if not hasattr(study, \\\"best_params\\\") or study.best_params is None:\\n\",\n",
    "    \"    raise RuntimeError(\\\"study.best_params를 찾지 못했습니다. Optuna가 정상 종료되었는지 확인해 주세요.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"best_params = dict(study.best_params)\\n\",\n",
    "    \"print(\\\"[Optuna] best_params =\\\", best_params)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 최종 학습 run 저장 위치\\n\",\n",
    "    \"final_name = \\\"final_from_optuna_best\\\"\\n\",\n",
    "    \"final_project = str(Path(cfg.work_dir) / \\\"final\\\")\\n\",\n",
    "    \"Path(final_project).mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Optuna가 선택한 모델 가중치(예: yolov8n.pt / yolo11n.pt ...)\\n\",\n",
    "    \"final_model_name = str(best_params.get(\\\"model\\\", getattr(cfg, \\\"base_model\\\", \\\"yolov8n.pt\\\")))\\n\",\n",
    "    \"final_model = YOLO(final_model_name)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (권장) 최종 학습은 탐색보다 더 길게\\n\",\n",
    "    \"final_epochs = int(getattr(cfg, \\\"epochs\\\", 300))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# ✅ VRAM 8GB 안전장치\\n\",\n",
    "    \"# - batch는 Optuna에서 4/8만 탐색하도록 바꿨지만,\\n\",\n",
    "    \"#   과거 study를 로드하는 경우 16이 들어있을 수도 있어 8로 상한을 둡니다.\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"batch_raw = int(best_params.get(\\\"batch\\\", getattr(cfg, \\\"batch\\\", 16)))\\n\",\n",
    "    \"batch_safe = min(batch_raw, 8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# imgsz는 요청대로 고정(cfg.imgsz) 사용\\n\",\n",
    "    \"imgsz = int(getattr(cfg, \\\"imgsz\\\", 640))\\n\",\n",
    "    \"\\n\",\n",
    "    \"final_results = final_model.train(\\n\",\n",
    "    \"    data=str(data_yaml),\\n\",\n",
    "    \"    imgsz=imgsz,\\n\",\n",
    "    \"    epochs=final_epochs,\\n\",\n",
    "    \"    batch=batch_safe,\\n\",\n",
    "    \"\\n\",\n",
    "    \"    lr0=float(best_params.get(\\\"lr0\\\", getattr(cfg, \\\"lr0\\\", 1e-3))),\\n\",\n",
    "    \"    weight_decay=float(best_params.get(\\\"weight_decay\\\", getattr(cfg, \\\"weight_decay\\\", 1e-4))),\\n\",\n",
    "    \"    optimizer=str(best_params.get(\\\"optimizer\\\", getattr(cfg, \\\"optimizer\\\", \\\"AdamW\\\"))),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # aug (색상은 0, 기하/혼합만 사용)\\n\",\n",
    "    \"    hsv_h=0.0, hsv_s=0.0, hsv_v=0.0,\\n\",\n",
    "    \"    degrees=float(best_params.get(\\\"degrees\\\", getattr(cfg, \\\"degrees\\\", 0.0))),\\n\",\n",
    "    \"    translate=float(best_params.get(\\\"translate\\\", getattr(cfg, \\\"translate\\\", 0.0))),\\n\",\n",
    "    \"    scale=float(best_params.get(\\\"scale\\\", getattr(cfg, \\\"scale\\\", 0.0))),\\n\",\n",
    "    \"    shear=float(best_params.get(\\\"shear\\\", getattr(cfg, \\\"shear\\\", 0.0))),\\n\",\n",
    "    \"    perspective=float(best_params.get(\\\"perspective\\\", getattr(cfg, \\\"perspective\\\", 0.0))),\\n\",\n",
    "    \"    fliplr=float(best_params.get(\\\"fliplr\\\", getattr(cfg, \\\"fliplr\\\", 0.0))),\\n\",\n",
    "    \"    flipud=float(best_params.get(\\\"flipud\\\", getattr(cfg, \\\"flipud\\\", 0.0))),\\n\",\n",
    "    \"    mosaic=float(best_params.get(\\\"mosaic\\\", getattr(cfg, \\\"mosaic\\\", 0.0))),\\n\",\n",
    "    \"    mixup=float(best_params.get(\\\"mixup\\\", getattr(cfg, \\\"mixup\\\", 0.0))),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    close_mosaic=int(getattr(cfg, \\\"close_mosaic\\\", 0)),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ✅ 메모리/로더 관련\\n\",\n",
    "    \"    amp=True,          # AMP는 기본 True지만, 명시해서 덮어씁니다. (메모리↓) \\n\",\n",
    "    \"    nbs=16,            # nominal batch size (loss 정규화)\\n\",\n",
    "    \"    workers=int(getattr(cfg, \\\"workers\\\", 0)),  # Windows면 0 고정\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # logging/output\\n\",\n",
    "    \"    project=final_project,\\n\",\n",
    "    \"    name=final_name,\\n\",\n",
    "    \"    exist_ok=True,\\n\",\n",
    "    \"    verbose=False,\\n\",\n",
    "    \"    val=True,\\n\",\n",
    "    \"    save=True,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"final_results\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"# 최종 best.pt 경로 확정 (다음 inference 셀에서 사용)\\n\",\n",
    "    \"# -------------------------\\n\",\n",
    "    \"final_save_dir = Path(getattr(final_results, \\\"save_dir\\\", Path(final_project) / final_name))\\n\",\n",
    "    \"cand_best = final_save_dir / \\\"weights\\\" / \\\"best.pt\\\"\\n\",\n",
    "    \"cand_last = final_save_dir / \\\"weights\\\" / \\\"last.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"if cand_best.exists():\\n\",\n",
    "    \"    FINAL_WEIGHTS = cand_best\\n\",\n",
    "    \"elif cand_last.exists():\\n\",\n",
    "    \"    FINAL_WEIGHTS = cand_last\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    FINAL_WEIGHTS = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"cfg.final_weights = str(FINAL_WEIGHTS) if FINAL_WEIGHTS else None\\n\",\n",
    "    \"print(\\\"✅ final_save_dir:\\\", str(final_save_dir))\\n\",\n",
    "    \"print(\\\"✅ FINAL_WEIGHTS :\\\", cfg.final_weights)\\n\"\n",
    "   ],\n",
