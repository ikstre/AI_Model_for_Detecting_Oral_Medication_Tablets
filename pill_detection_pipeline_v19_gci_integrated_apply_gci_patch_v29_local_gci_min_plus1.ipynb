    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"2430ede232a765bd\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3.5) 클래스 불균형(선택)\\n\",\n",
    "    \"\\n\",\n",
    "    \"- `compute_class_weight('balanced', ...)` 아이디어를 **탐지 문제에 직접(loss에) 넣기**는 쉽지 않아서, 여기서는 **학습 샘플링(train.txt)으로 간접 반영**합니다.\\n\",\n",
    "    \"- 기본은 모든 train 이미지를 1회 포함하고, `cfg.balance_extra_ratio` 만큼을 **가중치 기반으로 추가 샘플링**해서 train.txt에 덧붙입니다.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"ce5c0928e6746212\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# (선택) 클래스별 bbox 개수 확인 + balanced weight 계산\\n\",\n",
    "    \"train_class_cnt = count_class_instances(train_coco)\\n\",\n",
    "    \"print('n_classes:', len(train_class_cnt), ' | n_ann:', sum(train_class_cnt.values()))\\n\",\n",
    "    \"top10 = sorted(train_class_cnt.items(), key=lambda x: x[1], reverse=True)[:10]\\n\",\n",
    "    \"print('top10 by ann count:', top10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"class_w = compute_class_weight_from_coco(train_coco, method='balanced')\\n\",\n",
    "    \"w_top10 = [(cid, round(class_w.get(cid, 1.0), 3), train_class_cnt.get(cid, 0)) for cid,_ in top10]\\n\",\n",
    "    \"print('top10 weights (cid, weight, count):', w_top10)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"6ded1ab2\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 4) YOLO 학습용 데이터셋 내보내기\\n\",\n",
    "    \"#   - images/labels 폴더 생성 + (옵션) train/val.txt 리스트 생성(불균형 보정 포함)\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"out_root = cfg.yolo_dataset_dir\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_rel, val_rel = export_yolo_dataset(cfg.train_img_dir, train_coco, val_coco, catid_to_yolo, out_root)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (선택) 클래스 불균형 보정: train.txt에 \\\"추가 샘플\\\"을 append\\n\",\n",
    "    \"if getattr(cfg, \\\"balance_enable\\\", False) and float(getattr(cfg, \\\"balance_extra_ratio\\\", 0.0)) > 0:\\n\",\n",
    "    \"    class_w = compute_class_weight_from_coco(train_coco, method=\\\"balanced\\\")\\n\",\n",
    "    \"    train_list = make_weighted_train_list(\\n\",\n",
    "    \"        train_rel,\\n\",\n",
    "    \"        train_coco,\\n\",\n",
    "    \"        class_w,\\n\",\n",
    "    \"        extra_ratio=float(getattr(cfg, \\\"balance_extra_ratio\\\", 0.0)),\\n\",\n",
    "    \"        seed=int(getattr(cfg, \\\"seed\\\", 42)),\\n\",\n",
    "    \"        power=float(getattr(cfg, \\\"balance_power\\\", 1.0)),\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    train_list = train_rel\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ultralytics는 train/val에 txt list도 받을 수 있으므로, 교차플랫폼 & oversample에 유리합니다.\\n\",\n",
    "    \"train_txt = write_split_list(out_root, \\\"train\\\", train_list)\\n\",\n",
    "    \"val_txt   = write_split_list(out_root, \\\"val\\\",   val_rel)\\n\",\n",
    "    \"\\n\",\n",
    "    \"data_yaml = str(Path(out_root) / \\\"dataset.yaml\\\")\\n\",\n",
    "    \"write_dataset_yaml(\\n\",\n",
    "    \"    out_root,\\n\",\n",
    "    \"    names,\\n\",\n",
    "    \"    data_yaml,\\n\",\n",
    "    \"    train=Path(train_txt).name,\\n\",\n",
    "    \"    val=Path(val_txt).name,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"out_root:\\\", out_root)\\n\",\n",
    "    \"print(\\\"data_yaml:\\\", data_yaml)\\n\",\n",
    "    \"print(\\\"train_txt lines:\\\", len(train_list), \\\"| val_txt lines:\\\", len(val_rel))\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"faf6d0b5\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4.5) (호환) 기존 YOLO 라벨을 GCI로 치환 + dataset_gci.yaml 생성\\n\",\n",
    "    \"\\n\",\n",
    "    \"- `apply_gci_to_yolo.py`의 로직을 노트북에 통합한 셀입니다.\\n\",\n",
    "    \"- **과거에 로컬 인덱스(0..K-1)로 export된 labels**를, `global_category_index.json` 기준의 **global_index**로 치환할 때 사용합니다.\\n\",\n",
    "    \"- 이미 GCI 모드로 export했다면, 라벨 치환은 필요 없고 `dataset_gci.yaml`만 생성해도 됩니다.\\n\",\n",
    "    \"\\n\",\n",
    "    \"사용:\\n\",\n",
    "    \"- 로컬로 export된 라벨을 GCI로 바꾸고 싶으면 `cfg.force_apply_gci_remap = True`로 설정 후 실행하세요.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"be438b1e\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 4.5) (호환) apply_gci_to_yolo.py 로직 통합\\n\",\n",
    "    \"# - 로컬 YOLO 인덱스(0..K-1)로 export된 labels를 GCI global_index로 치환\\n\",\n",
    "    \"# - GCI 전체 names를 포함한 dataset_gci.yaml 생성\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _load_gci(gci_json_path: str):\\n\",\n",
    "    \"    gci_json_path = Path(gci_json_path)\\n\",\n",
    "    \"    with open(gci_json_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"        gci = json.load(f)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    id_to_index = {int(k): int(v) for k, v in gci[\\\"id_to_index\\\"].items()}\\n\",\n",
    "    \"    index_to_id = {int(k): int(v) for k, v in gci[\\\"index_to_id\\\"].items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    raw_cat_map = gci.get(\\\"category_map\\\", {})\\n\",\n",
    "    \"    category_map = {int(k): v for k, v in raw_cat_map.items()}\\n\",\n",
    "    \"    total_categories = int(gci[\\\"metadata\\\"][\\\"total_categories\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return id_to_index, index_to_id, category_map, total_categories\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _build_local_categories_csv_from_coco(coco: dict, out_csv: str):\\n\",\n",
    "    \"    # categories를 category_id로 정렬하고 row index를 로컬 cls로 쓰는 구조 (apply_gci_to_yolo.py 가정)\\n\",\n",
    "    \"    cats = coco.get(\\\"categories\\\", [])\\n\",\n",
    "    \"    df = pd.DataFrame([{\\\"category_id\\\": int(c[\\\"id\\\"]), \\\"category_name\\\": c.get(\\\"name\\\", \\\"\\\")} for c in cats])\\n\",\n",
    "    \"    df = df.drop_duplicates(subset=[\\\"category_id\\\"]).sort_values(\\\"category_id\\\").reset_index(drop=True)\\n\",\n",
    "    \"    Path(out_csv).parent.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"    df.to_csv(out_csv, index=False, encoding=\\\"utf-8-sig\\\")\\n\",\n",
    "    \"    return out_csv, df\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _build_local_idx_to_catid(local_categories_csv: str):\\n\",\n",
    "    \"    df = pd.read_csv(local_categories_csv)\\n\",\n",
    "    \"    if \\\"category_id\\\" not in df.columns:\\n\",\n",
    "    \"        raise ValueError(\\\"local_categories_csv에 'category_id' 컬럼이 없습니다.\\\")\\n\",\n",
    "    \"    local_idx_to_catid = {int(i): int(row[\\\"category_id\\\"]) for i, row in df.iterrows()}\\n\",\n",
    "    \"    return local_idx_to_catid, df\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _remap_labels_to_global(labels_dir: str, local_idx_to_global_idx: dict):\\n\",\n",
    "    \"    labels_dir = Path(labels_dir)\\n\",\n",
    "    \"    txt_files = list(labels_dir.rglob(\\\"*.txt\\\"))\\n\",\n",
    "    \"    if not txt_files:\\n\",\n",
    "    \"        print(f\\\"[WARN] 라벨 txt가 없습니다: {labels_dir}\\\")\\n\",\n",
    "    \"        return 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    changed = 0\\n\",\n",
    "    \"    for txt_path in tqdm(txt_files, desc=\\\"Remapping labels\\\", leave=False):\\n\",\n",
    "    \"        lines = txt_path.read_text(encoding=\\\"utf-8\\\").strip().splitlines()\\n\",\n",
    "    \"        if len(lines) == 1 and lines[0] == \\\"\\\":\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        lines_out = []\\n\",\n",
    "    \"        modified = False\\n\",\n",
    "    \"        for line in lines:\\n\",\n",
    "    \"            parts = line.strip().split()\\n\",\n",
    "    \"            if len(parts) < 5:\\n\",\n",
    "    \"                lines_out.append(line)\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            local_cls = int(float(parts[0]))\\n\",\n",
    "    \"            if local_cls not in local_idx_to_global_idx:\\n\",\n",
    "    \"                raise ValueError(f\\\"[ERROR] {txt_path}에서 local class {local_cls}를 매핑할 수 없습니다.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            global_cls = int(local_idx_to_global_idx[local_cls])\\n\",\n",
    "    \"            if global_cls != local_cls:\\n\",\n",
    "    \"                modified = True\\n\",\n",
    "    \"            parts[0] = str(global_cls)\\n\",\n",
    "    \"            lines_out.append(\\\" \\\".join(parts))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if modified:\\n\",\n",
    "    \"            txt_path.write_text(\\\"\\\\n\\\".join(lines_out) + \\\"\\\\n\\\", encoding=\\\"utf-8\\\")\\n\",\n",
    "    \"            changed += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return changed\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _write_gci_yaml(\\n\",\n",
    "    \"    output_yaml_path: str,\\n\",\n",
    "    \"    dataset_root: str,\\n\",\n",
    "    \"    train_rel: str,\\n\",\n",
    "    \"    val_rel: str,\\n\",\n",
    "    \"    total_categories: int,\\n\",\n",
    "    \"    index_to_id: dict,\\n\",\n",
    "    \"    category_map: dict,\\n\",\n",
    "    \"):\\n\",\n",
    "    \"    output_yaml_path = Path(output_yaml_path)\\n\",\n",
    "    \"    dataset_root = str(Path(dataset_root))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    lines = []\\n\",\n",
    "    \"    lines.append(f\\\"path: {dataset_root}\\\")\\n\",\n",
    "    \"    lines.append(f\\\"train: {train_rel}\\\")\\n\",\n",
    "    \"    lines.append(f\\\"val: {val_rel}\\\")\\n\",\n",
    "    \"    lines.append(\\\"\\\")\\n\",\n",
    "    \"    lines.append(f\\\"nc: {total_categories}\\\")\\n\",\n",
    "    \"    lines.append(\\\"names:\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for idx in range(total_categories):\\n\",\n",
    "    \"        cat_id = index_to_id.get(idx)\\n\",\n",
    "    \"        if cat_id is None:\\n\",\n",
    "    \"            name = \\\"Unknown\\\"\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            name = category_map.get(cat_id, {}).get(\\\"category_name\\\", \\\"Unknown\\\")\\n\",\n",
    "    \"            name = str(name).replace(\\\"'\\\", \\\"''\\\")\\n\",\n",
    "    \"        lines.append(f\\\"  {idx}: '{name}'\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    output_yaml_path.write_text(\\\"\\\\n\\\".join(lines) + \\\"\\\\n\\\", encoding=\\\"utf-8-sig\\\")\\n\",\n",
    "    \"    return str(output_yaml_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ---- 실행부 ----\\n\",\n",
    "    \"cfg.force_apply_gci_remap = bool(getattr(cfg, \\\"force_apply_gci_remap\\\", False))\\n\",\n",
    "    \"gci_path = Path(getattr(cfg, \\\"gci_json_path\\\", \\\"\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"yolo_dir = Path(getattr(cfg, \\\"yolo_dataset_dir\\\", \\\"yolo_dataset\\\"))\\n\",\n",
    "    \"labels_dir = yolo_dir / \\\"labels\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# export 단계에서 만들어진 train/val txt를 우선 사용 (없으면 images/로 fallback)\\n\",\n",
    "    \"train_ref = Path(\\\"train.txt\\\") if (yolo_dir / \\\"train.txt\\\").exists() else Path(\\\"images\\\")\\n\",\n",
    "    \"val_ref   = Path(\\\"val.txt\\\")   if (yolo_dir / \\\"val.txt\\\").exists()   else Path(\\\"images\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"if not gci_path.exists():\\n\",\n",
    "    \"    print(\\\"[GCI APPLY] skip: gci_json_path not found ->\\\", gci_path)\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    id_to_index, index_to_id, category_map, total_categories = _load_gci(str(gci_path))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 로컬 categories.csv가 없으면 COCO에서 생성\\n\",\n",
    "    \"    local_csv = Path(yolo_dir) / \\\"local_categories.csv\\\"\\n\",\n",
    "    \"    if not local_csv.exists():\\n\",\n",
    "    \"        _build_local_categories_csv_from_coco(train_coco, str(local_csv))\\n\",\n",
    "    \"        print(\\\"[GCI APPLY] local_categories.csv 생성:\\\", local_csv)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 라벨 치환은 '로컬로 export된 데이터셋을 GCI로 바꾸고 싶을 때'만 수행\\n\",\n",
    "    \"    if cfg.force_apply_gci_remap:\\n\",\n",
    "    \"        local_idx_to_catid, _ = _build_local_idx_to_catid(str(local_csv))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 로컬 idx -> 전역 idx\\n\",\n",
    "    \"        local_idx_to_global_idx = {}\\n\",\n",
    "    \"        for local_idx, cat_id in local_idx_to_catid.items():\\n\",\n",
    "    \"            if cat_id not in id_to_index:\\n\",\n",
    "    \"                raise ValueError(f\\\"[ERROR] category_id={cat_id}가 GCI에 없습니다. (local_idx={local_idx})\\\")\\n\",\n",
    "    \"            local_idx_to_global_idx[local_idx] = id_to_index[cat_id]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        changed_files = _remap_labels_to_global(str(labels_dir), local_idx_to_global_idx)\\n\",\n",
    "    \"        print(f\\\"[GCI APPLY] 수정된 라벨 파일 수: {changed_files:,} / labels 총 파일 수: {len(list(labels_dir.rglob('*.txt'))):,}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"[GCI APPLY] 라벨 치환은 생략합니다. (cfg.force_apply_gci_remap=False)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # export 단계에서 USE_GCI가 True였다면 라벨은 이미 global_index입니다.\\n\",\n",
    "    \"    export_used_gci = bool(globals().get(\\\"USE_GCI\\\", False))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if cfg.force_apply_gci_remap or export_used_gci:\\n\",\n",
    "    \"        # (요청) train split subset을 쓰는 경우, nc/names도 subset으로 YAML 생성\\n\",\n",
    "    \"        use_subset = bool(getattr(cfg, \\\"gci_use_train_subset\\\", False)) and (\\\"SUBMIT_INDEX_TO_ID\\\" in globals())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if use_subset:\\n\",\n",
    "    \"            subset_index_to_id = {int(k): int(v) for k, v in SUBMIT_INDEX_TO_ID.items()}\\n\",\n",
    "    \"            subset_total = len(subset_index_to_id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            out_yaml = yolo_dir / \\\"dataset_gci_train_subset.yaml\\\"\\n\",\n",
    "    \"            saved_yaml = _write_gci_yaml(\\n\",\n",
    "    \"                output_yaml_path=str(out_yaml),\\n\",\n",
    "    \"                dataset_root=str(yolo_dir),\\n\",\n",
    "    \"                train_rel=str(train_ref),\\n\",\n",
    "    \"                val_rel=str(val_ref),\\n\",\n",
    "    \"                total_categories=subset_total,\\n\",\n",
    "    \"                index_to_id=subset_index_to_id,\\n\",\n",
    "    \"                category_map=category_map,\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"            print(\\\"[GCI APPLY] dataset_gci_train_subset.yaml 생성:\\\", saved_yaml)\\n\",\n",
    "    \"            print(\\\"[GCI APPLY] nc =\\\", subset_total, \\\"| index_range:\\\", f\\\"0-{subset_total-1}\\\")\\n\",\n",
    "    \"            print(\\\"[GCI APPLY] (권장) 학습/평가에는 dataset.yaml(=subset) 또는 dataset_gci_train_subset.yaml을 사용하세요.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            # (기본) 전역 GCI YAML 생성 (labels가 global index라는 전제)\\n\",\n",
    "    \"            out_yaml = yolo_dir / \\\"dataset_gci.yaml\\\"\\n\",\n",
    "    \"            saved_yaml = _write_gci_yaml(\\n\",\n",
    "    \"                output_yaml_path=str(out_yaml),\\n\",\n",
    "    \"                dataset_root=str(yolo_dir),\\n\",\n",
    "    \"                train_rel=str(train_ref),\\n\",\n",
    "    \"                val_rel=str(val_ref),\\n\",\n",
    "    \"                total_categories=total_categories,\\n\",\n",
    "    \"                index_to_id=index_to_id,\\n\",\n",
    "    \"                category_map=category_map,\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"            print(\\\"[GCI APPLY] dataset_gci.yaml 생성:\\\", saved_yaml)\\n\",\n",
    "    \"            print(\\\"[GCI APPLY] nc =\\\", total_categories, \\\"| index_range:\\\", f\\\"0-{total_categories-1}\\\")\\n\",\n",
    "    \"            if cfg.force_apply_gci_remap:\\n\",\n",
    "    \"                print(\\\"[GCI APPLY] 이제 학습/평가에는 dataset_gci.yaml을 쓰는 것을 권장합니다.\\\")\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                print(\\\"[GCI APPLY] (skip) export가 로컬 인덱스였고, 라벨 치환도 하지 않았습니다.\\\")\\n\",\n",
    "    \"                print(\\\"          -> 현재 dataset.yaml을 그대로 사용하세요.\\\")\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"2e57ac92\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5) Train (baseline)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"d26c5f6d\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# =========================\\n\",\n",
    "    \"# 5) 베이스라인 학습 (옵션)\\n\",\n",
    "    \"# - Optuna 전에 \\\"데이터/파이프라인이 정상인지\\\" 빠르게 확인용입니다.\\n\",\n",
    "    \"# - VRAM 8GB 환경이면 AutoBatch + AMP로 안전하게 돌리는 쪽이 좋습니다.\\n\",\n",
    "    \"# =========================\\n\",\n",
    "    \"\\n\",\n",
    "    \"RUN_BASELINE = False  # ✅ 필요할 때만 True로 바꿔 실행하세요.\\n\",\n",
    "    \"\\n\",\n",
    "    \"if RUN_BASELINE:\\n\",\n",
    "    \"    model = build_yolo_model(cfg.base_model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    baseline = train_yolo(\\n\",\n",
    "    \"        model,\\n\",\n",
    "    \"        data_yaml=data_yaml,\\n\",\n",
    "    \"        cfg=cfg,\\n\",\n",
    "    \"        epochs=10,\\n\",\n",
    "    \"        project=cfg.work_dir,\\n\",\n",
    "    \"        name=cfg.baseline_name,\\n\",\n",
    "    \"        exist_ok=True,\\n\",\n",
    "    \"        batch=-1,   # ✅ AutoBatch(약 60% GPU 메모리)로 OOM 방지\\n\",\n",
    "    \"        amp=True,   # ✅ mixed precision (메모리↓)\\n\",\n",
    "    \"        workers=int(getattr(cfg, \\\"workers\\\", 0)),  # Windows면 0 권장\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    baseline\\n\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"19b2462f88a4cb0e\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"### (옵션) 여러 YOLO 버전/크기 빠르게 비교하기\\n\",\n",
    "    \"\\n\",\n",
    "    \"- `cfg.model_candidates`에 여러 가중치 이름을 넣고, 아래 셀을 실행하면 **각 후보별로 베이스라인을 1회 학습**합니다.\\n\",\n",
    "    \"- 시간이 많이 걸릴 수 있으니 필요할 때만 실행해 주세요.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"2af4b9aa36b62f0a\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# 여러 모델 후보를 한 번씩 학습해보고 싶을 때 사용\\n\",\n",
    "    \"# results = []\\n\",\n",
    "    \"# for mname in getattr(cfg, 'model_candidates', [cfg.base_model]):\\n\",\n",
    "    \"#     print('\\\\n' + '='*80)\\n\",\n",
    "    \"#     print('MODEL:', mname)\\n\",\n",
    "    \"#     print('='*80)\\n\",\n",
    "    \"#     m = build_yolo_model(mname)\\n\",\n",
    "    \"#     r = train_yolo(\\n\",\n",
    "    \"#         m,\\n\",\n",
    "    \"#         data_yaml=data_yaml,\\n\",\n",
    "    \"#         cfg=cfg,\\n\",\n",
    "    \"#         epochs=cfg.epochs,\\n\",\n",
    "    \"#         project=cfg.work_dir,\\n\",\n",
    "    \"#         name=f\\\"{cfg.baseline_name}_{Path(mname).stem}\\\",\\n\",\n",
    "    \"#         exist_ok=True,\\n\",\n",
    "    \"#     )\\n\",\n",
    "    \"#     results.append((mname, r))\\n\",\n",
    "    \"# results\\n\"\n",
    "   ],\n",
